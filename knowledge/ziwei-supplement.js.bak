
  // ═════════════════════════════════════════════════
  // 十六、六吉星入十二宫详解（新增·深度补充）
  // ═════════════════════════════════════════════════
  window.ZIWEI_KB.sixAuspiciousPalaces = {
    title: '六吉星入十二宫详解',
    intro: '六吉星（左辅、右弼、天魁、天钺、文昌、文曲）各入十二宫，各有不同的吉兆和影响。六吉星的主作用在于助力和提升，但若与煞星同宫，其吉性也会被削弱。《太微赋》曰：「吉星临照，福自天来；煞星暗伏，祸从地起。」吉星的加持需要命盘有好的根基才能发挥最大效用。',
    zuofu: {
      title: '左辅入十二宫',
      note: '左辅属阳土，为北斗帝座之辅星。主阳贵、明助、同辈提携。左辅之力如公开的帮手，明面上的助力。入各宫表现如下：',
      palaces: [
        { palace: '命宫', desc: '左辅入命，为人宽厚仁慈，善与人合作共事。命宫左辅者天生有帮手缘，遇事有人主动相助。若与右弼同宫或三方拱照，则贵人运极强，一生得人辅佐。左辅入命者性格稳定，做事有始有终，适合团队合作型工作。但若煞星同宫，则助力大打折扣，贵人变小人。' },
        { palace: '兄弟宫', desc: '兄弟宫左辅，主手足情深，兄弟姐妹之间互相扶持。兄弟中有人品性宽厚者，能成为自己的得力助手。若为独生子女，则朋友如兄弟，朋友中有可信赖之人。左辅在兄弟宫也暗示与合作伙伴关系良好，适合与人合伙创业。' },
        { palace: '夫妻宫', desc: '夫妻宫左辅，主配偶为贤内助，夫妻互相扶持共度人生。配偶为人宽厚，善于处理人际关系，能在事业和生活上给予实际帮助。婚姻基础稳定，夫妻如搭档般默契配合。但左辅在夫妻宫也可能暗示配偶身边有异性助手，需注意分寸。' },
        { palace: '子女宫', desc: '子女宫左辅，主子女孝顺且有出息，子女长大后能成为自己的帮手。子女性格宽厚，善于与人相处。此宫左辅也暗示生育较为顺利，子女身体健康。在教育子女方面，以鼓励和辅助为主，不宜过度严厉。' },
        { palace: '财帛宫', desc: '财帛宫左辅，主财运上得人相助，适合合作求财。有朋友或同事在财务方面给予实际帮助，赚钱有帮手。适合从事需要团队合作的行业，不宜单打独斗。左辅在财帛也暗示收入渠道不止一条，有正职之外的补充财源。' },
        { palace: '疾厄宫', desc: '疾厄宫左辅，主体质较有韧性，生病时能得良医良药。左辅在疾厄有「遇难有救」之意，即使生病也能及时得到好的医疗资源。但若煞星同宫，则虽有救但过程波折。平时应养成健康的生活习惯，善待身体。' },
        { palace: '迁移宫', desc: '迁移宫左辅，主外出有人相助，适合到外地发展。出外时容易遇到主动伸出援手的人，旅途顺利。在异地工作和生活能建立好的人际关系网。左辅在迁移也暗示适合从事需要频繁外出的工作，如销售、业务、出差等。' },
        { palace: '交友宫', desc: '交友宫左辅为最佳宫位之一。主朋友众多且朋友可靠，下属得力。左辅在交友者社交能力强，善于团结群众。朋友中有能力出众者，能给自己实质帮助。适合从事需要人脉资源的行业，朋友即财富。' },
        { palace: '官禄宫', desc: '官禄宫左辅，主事业上有得力助手或下属，工作上得同事配合。适合在团队中担任协调的角色，能团结同事共同完成目标。上司也会看重你的协作能力。左辅在官禄暗示事业宜合不宜分，不宜单打独斗创业。' },
        { palace: '田宅宫', desc: '田宅宫左辅，主家宅和睦，家人互相扶持。家庭中有互助的氛围，家人是自己最坚强的后盾。左辅在田宅也暗示房产方面有贵人相助，如购房时有人提供好的建议或帮助。家庭关系和谐，适合大家庭生活。' },
        { palace: '福德宫', desc: '福德宫左辅，主精神生活充实，晚年有人陪伴和照顾。内心宽厚，能真心为他人着想。老年时有朋友和晚辈的关爱，不孤单。左辅在福德者懂得享受生活中的人际温暖，知足常乐。' },
        { palace: '父母宫', desc: '父母宫左辅，主父母宽厚仁慈，给予自己充分的支持和帮助。家庭教育以鼓励为主，父母是自己最早的贵人。与上司、长辈关系良好，易得提拔和赏识。左辅在父母也暗示有祖荫，父母留下的人脉和资源可以受益。' }
      ]
    },
    youbi: {
      title: '右弼入十二宫',
      note: '右弼属阴土，为北斗帝座之辅弼。主阴贵、暗助、幕后贵人。右弼之力如暗中相助，受人之恩常不自知。与左辅相比，右弼更加内敛含蓄。',
      palaces: [
        { palace: '命宫', desc: '右弼入命，主为人内秀含蓄，暗中有人相助而不自知。右弼命者心思细腻，善于发现他人的需求，因此也容易获得他人的暗中帮助。若与左辅同宫或对拱，则左右拱主，贵人运极佳。右弼入命者女性气质较浓，男性则偏柔和。' },
        { palace: '兄弟宫', desc: '兄弟宫右弼，主兄弟中有暗中关心自己之人，手足情谊内敛而深厚。兄弟之间不一定经常联系，但关键时刻会挺身而出。右弼在兄弟也暗示与合作伙伴的关系虽不张扬但稳固，适合长期合作而非短期利益交换。' },
        { palace: '夫妻宫', desc: '夫妻宫右弼，主配偶温柔体贴，在背后默默支持自己。配偶不喜张扬，但做的比说的多。婚姻关系如同细水长流，感情在内不在外。右弼在夫妻宫的女性配偶缘较好，丈夫体贴细心。但需注意右弼也可能暗示配偶有秘密。' },
        { palace: '子女宫', desc: '子女宫右弼，主子女细腻体贴，虽不善于表达但对父母的孝心深厚。子女性格内秀，学习能力强。教育子女时应注重情感沟通，以柔克刚。右弼在子女也暗示与晚辈、学生的关系融洽，他们会在你需要时默默支持你。' },
        { palace: '财帛宫', desc: '财帛宫右弼，主财运得暗中之助，有些赚钱机会是别人引荐但不张扬的。适合从事需要细心和耐心的行业。右弼在财帛者不会炫耀财富，但实际经济状况比表面看起来好。暗中理财能力较强，善于发现别人忽略的赚钱机会。' },
        { palace: '疾厄宫', desc: '疾厄宫右弼，主体质虽非最强壮但有韧性，恢复力好。生病时容易遇到好的医生和有效的治疗，但不一定是最有名的医生。右弼在疾厄暗示需注意慢性疾病的预防，因为右弼之力缓慢而持久，同理疾病也可能暗中发展。' },
        { palace: '迁移宫', desc: '迁移宫右弼，主出外时暗中有人照应。适合到外地从事需要细心和耐心的工作。右弼在迁移者在外虽不张扬但人缘好，容易融入新环境。外出旅行时总有意外的贵人相助，化险为夷。适合文化、教育等需要内在修养的外出工作。' },
        { palace: '交友宫', desc: '交友宫右弼，主朋友多内秀之人，朋友关系以心意相通为主。下属做事细心可靠，不张扬但有实效。右弼在交友者不善于大规模社交，但有几个知心好友足以。朋友的帮助常常润物无声，不经意间给予关键支持。' },
        { palace: '官禄宫', desc: '官禄宫右弼，主事业上得幕后贵人提携。可能有人暗中推荐或帮助，自己甚至不知道。适合从事需要细心和耐心的行业，如行政、文秘、后勤、客服等。右弼在官禄者事业发展不是爆发型而是稳步上升型，厚积薄发。' },
        { palace: '田宅宫', desc: '田宅宫右弼，主家宅温馨舒适，虽不豪华但有家的温暖。家庭关系以细腻的情感为纽带。右弼在田宅也暗示房产投资方面需耐心，不宜急于求成。家人之间互相体谅，有困难时暗中相助，家的感觉深厚。' },
        { palace: '福德宫', desc: '福德宫右弼，主精神生活滋养丰富，内心柔软善良。晚年有人默默照顾，不孤单。右弼在福德者能从艺术、音乐、文学中获得内心满足。喜欢安静的生活，知足常乐，对物质要求不高但精神世界充实。' },
        { palace: '父母宫', desc: '父母宫右弼，主父母慈爱但不张扬，默默为自己付出。家庭教育以温情为主，父母言传身教。与上司的关系如师徒般，上司会在暗中培养和提携自己。右弼在父母暗示长辈之爱如春雨润物，需用心体会才知其深。' }
      ]
    },
    tiankui: {
      title: '天魁入十二宫',
      note: '天魁属阳火，为南斗阳贵，化气为阳贵。主显性贵人、社会名望、官方认可、公开提携。天魁之力如公开的贵人，社会上有地位的人伸出援手。',
      palaces: [
        { palace: '命宫', desc: '天魁入命，主人相貌堂堂，气质出众，易得社会名流赏识。天魁命者天生有贵人缘，从小到大总有人主动帮助。在关键的考试、求职、竞选中容易脱颖而出。天魁坐命者适合从事需要社会认可的职业，如公务员、律师、教授等。但天魁也暗示需靠贵人提携，自身实力也要跟上。' },
        { palace: '兄弟宫', desc: '兄弟宫天魁，主兄弟中有社会地位较高者，能给自己带来社会资源和机会。手足中有人出人头地，可以相互提携。天魁在兄弟也暗示合作伙伴中有知名人士，合作能提升自己的社会形象。' },
        { palace: '夫妻宫', desc: '夫妻宫天魁，主配偶有社会地位或在某领域有声望。配偶能给自己带来社会资源的提升，婚姻有「高攀」之意。配偶性格正直，注重社会形象。天魁在夫妻暗示婚姻可能是通过贵人介绍或在工作场合结识，姻缘体面。' },
        { palace: '子女宫', desc: '子女宫天魁，主子女学业优异、考运好，将来有社会地位。子女容易得到名师或贵人的提携，在关键节点有突破。天魁在子女也暗示子女在升学、就业方面有贵人相助，不需要父母太过操心。' },
        { palace: '财帛宫', desc: '财帛宫天魁，主通过社会地位和人际关系获取财富。适合从事需要社会声望的行业，如咨询服务、中介、高端销售等。天魁在财帛者赚钱讲究体面，不取不义之财。有些赚钱机会是通过贵人介绍的，不宜闷头单干。' },
        { palace: '疾厄宫', desc: '疾厄宫天魁，主生病时容易遇到名医，得到好的医疗资源。天魁为阳贵在疾厄，有「天医星」之象，病情容易被正确诊断和有效治疗。但天魁也暗示需注意因社会应酬过多导致的身体问题，如饮食不节引起的三高。' },
        { palace: '迁移宫', desc: '迁移宫天魁，主外出发展容易得到当地有头有脸人物的帮助。适合到外地从政、任教或从事需要社会地位的工作。出外时形象好、口碑佳，容易建立社会人脉。天魁在迁移暗示出外有贵气，适合在外地追求社会地位。' },
        { palace: '交友宫', desc: '交友宫天魁，主朋友中有社会名流、有地位之人。社交圈子层次较高，能通过与朋友交往提升自己的社会地位。下属中有能力强者，值得培养和信赖。天魁在交友者为朋友中的组织者，人脉资源丰富。' },
        { palace: '官禄宫', desc: '官禄宫天魁为最佳宫位之一。主事业上有贵人提携，步步高升。适合从政、公务员、大型企业等有明确晋升通道的组织。天魁在官禄者容易得到领导的赏识和提拔，事业上升路径清晰。加上自身努力，可望达到较高的社会地位。' },
        { palace: '田宅宫', desc: '田宅宫天魁，主家宅有气派，家庭在社会上有地位。可能祖上有名望，或是自己白手起家在社会上挣得地位。天魁在田宅也暗示房产投资方面会遇到好的机会和贵人指点。家庭氛围比较注重社会形象。' },
        { palace: '福德宫', desc: '福德宫天魁，主晚年有社会地位，受人尊敬。精神追求偏向于社会认可和名誉，注重名声。天魁在福德者晚年可能继续参与社会活动，不甘寂寞。内心对「面子」比较看重，好处是这驱动自己维持良好的社会形象。' },
        { palace: '父母宫', desc: '父母宫天魁为最佳宫位之一。主父母有社会地位和名望，给自己奠定好的社会基础。家庭教育注重体面和尊严，父母是自己最大的贵人。与上司关系如父子，上司会像父亲一样提携自己。天魁在父母者天生站在较高的社会起点。' }
      ]
    },
    tianyue: {
      title: '天钺入十二宫',
      note: '天钺属阴火，为南斗阴贵，化气为阴贵。主隐性贵人、暗中相助、幕后提携、无形的社会资源。天钺之力如暗中庇佑，贵人常在幕后。',
      palaces: [
        { palace: '命宫', desc: '天钺入命，主暗中有人守护，遇事总有看不见的手在帮忙。天钺命者不张扬但有贵人运，常常是事成之后才知有人背后出力。适合从事幕后工作如顾问、策划、幕僚等。天钺与天魁同宫或对拱为魁钺交会格，一生贵人运极旺。天钺入命者感恩之心重要，须知恩图报。' },
        { palace: '兄弟宫', desc: '兄弟宫天钺，主兄弟中有在幕后默默帮助自己之人。手足间有暗中的默契和相互支持。天钺在兄弟也暗示合作关系中有一方甘居幕后，配合默契。与合作伙伴的关系虽不公开但很稳固。' },
        { palace: '夫妻宫', desc: '夫妻宫天钺，主配偶是自己的暗中贵人，默默为家庭付出不居功。配偶可能不善于公开表达爱，但实际行动中处处体现关怀。婚姻中有一方在幕后支持另一方的事业，是典型的「成功男人（女人）背后的女人（男人）」。天钺在夫妻者应多多感恩配偶的付出。' },
        { palace: '子女宫', desc: '子女宫天钺，主子女有暗中的贵人相助，学业和成长中总有人暗中照顾。子女可能不善于表达对父母的爱，但心中孝顺。天钺在子女暗示子女不需要父母过分操心，自己会遇到好的老师或引路人。' },
        { palace: '财帛宫', desc: '财帛宫天钺，主财运得暗中之助，有些收入是别人暗中牵线或引荐。适合从事幕后策划、投资顾问等不抛头露面的行业。天钺在财帛者赚钱不张扬，闷声发大财。财运的特点是稳定且不易被外人察觉，适合低调理财。' },
        { palace: '疾厄宫', desc: '疾厄宫天钺，主疾病容易在早期被发现并及时治疗。天钺为阴贵在疾厄，有「暗中庇护」之象，大病化小、小病化了。但天钺之力隐而不显，平时仍需定期体检，不能完全依赖运气。天钺在疾厄也暗示适合中医、针灸等传统疗法。' },
        { palace: '迁移宫', desc: '迁移宫天钺，主外出时有暗中的保护力量。适合到外地从事幕后型工作，或在外地低调发展。天钺在迁移者出外时不要太高调，暗中发展反而更顺。旅途中遇到困难时总有贵人暗中相助，化险为夷。' },
        { palace: '交友宫', desc: '交友宫天钺，主朋友中有暗中帮助自己的幕后英雄。朋友关系不以数量取胜，而是有几个关键时刻能出手相助的知交。下属忠心可靠，愿意在背后默默支持。天钺在交友者不宜在朋友圈中过于高调，低调反而得人心。' },
        { palace: '官禄宫', desc: '官禄宫天钺，主事业上有幕后贵人相助。适合从事幕后策划、研究、顾问等工作。天钺在官禄者可能有一位不露面的导师或领导在暗中栽培自己，时机成熟时才会有公开的提拔。事业发展的路径是暗线而非明线。' },
        { palace: '田宅宫', desc: '田宅宫天钺，主家庭有暗中的福气庇护。家宅虽不张扬但风水好、气场佳。天钺在田宅也暗示房产方面适合低调投资，不宜炫富。家庭的幸福感在于内心的满足而非外在的炫耀，家中有一种隐秘的温馨。' },
        { palace: '福德宫', desc: '福德宫天钺，主精神世界充实，内心有信仰或精神寄托。晚年有人暗中照顾，福气深厚但不显露。天钺在福德者内心感恩知足，精神修养较高。喜欢安静的晚年生活，可能皈依宗教或从事公益慈善以回馈社会。' },
        { palace: '父母宫', desc: '父母宫天钺，主父母在幕后为自己铺路，付出不求回报。父母可能不善言辞但实际做了很多。与上司的关系如良师益友，上司会在暗中给机会。天钺在父母者需用心体会长辈的良苦用心，他们常常做了很多你不知道的事。' }
      ]
    },
    wenchang: {
      title: '文昌入十二宫',
      note: '文昌属阳金，为南斗文星，化气为文魁。主学业、文采、证书、学历、科甲功名。文昌之力如正规之学，主传统的学术成就和考试运。',
      palaces: [
        { palace: '命宫', desc: '文昌入命，主聪明好学，文采出众，有利考运和学术研究。文昌坐命者学习能力强，善于归纳总结、条理清晰。适合从事教育、写作、科研、法律等需要文字功底的行业。文昌在命也暗示为人重规矩，做事有条理，但有时过于求全责备。加天梁太阳化禄则阳梁昌禄格成。' },
        { palace: '兄弟宫', desc: '兄弟宫文昌，主兄弟中有学业优异者，手足间可以互相切磋学问。文昌在兄弟暗示家庭中有重学的传统，兄弟姐妹在学习上互相促进。与合作伙伴的关系偏向于知识和信息的共享，适合与有学识的人合伙。' },
        { palace: '夫妻宫', desc: '夫妻宫文昌，主配偶有学识修养，夫妻以文会友、相敬如宾。配偶可能是通过学校、工作等正式场合认识的。文昌在夫妻暗示婚姻讲究门当户对、文化层次相当。但夫妻间可能缺少激情，偏向理性和文明相处。' },
        { palace: '子女宫', desc: '子女宫文昌，主子女学业优良，考试成绩好，有学术天赋。文昌在子女者应注重子女的教育投资，子女在正规教育体系中有优势。子女命中有科甲之运，容易考入名校。但需注意不要给子女太大压力，顺其自然。' },
        { palace: '财帛宫', desc: '财帛宫文昌，主以知识和学术赚钱。适合从事教育、写作、出版、法律等需要专业知识的行业。文昌在财帛者赚钱方式正规体面，善于做财务规划和分析。但偏财运较弱，不宜投机取巧。财富需要靠专业知识和学历来换取。' },
        { palace: '疾厄宫', desc: '疾厄宫文昌，主体质方面需注意神经系统和呼吸系统。文昌属金入疾厄，金主肺和大肠，需注意呼吸道健康。但文昌为吉星在疾厄，暗示通过学习和知识可以更好地管理健康。此人可能对医学知识有兴趣，能自己研究养生之道。' },
        { palace: '迁移宫', desc: '迁移宫文昌，主适合外出求学、深造或参加学术交流。到外地读书或进修的机会多。文昌在迁移暗示外出有名声，适合在外地从事教育和文化工作。去文化氛围浓厚的城市或国家对自己有利。' },
        { palace: '交友宫', desc: '交友宫文昌，主朋友多文人学者，社交圈子文化层次高。朋友中有学识渊博者，可以互相交流学习。文昌在交友者参加读书会、学术沙龙有利。下属员工文化素质较高，适合知识型团队。' },
        { palace: '官禄宫', desc: '官禄宫文昌为最佳宫位之一。主以文取贵，适合从事教育、学术、法律、写作、出版等行业。文昌在官禄者事业发展路径清晰，通过学历提升和专业深耕获得晋升。有科甲之运，考试运、职称评定运好。加天梁太阳化禄成阳梁昌禄格。' },
        { palace: '田宅宫', desc: '田宅宫文昌，主家中有书香气息，注重文化教育。住宅环境安静雅致，适合读书学习。文昌在田宅暗示有利于购置学区房或文化底蕴深厚的房产。家中藏书丰富，有好的学习氛围代代相传。' },
        { palace: '福德宫', desc: '福德宫文昌，主精神生活以学习和阅读为主。晚年仍好学不倦，精神世界充实。文昌在福德者喜欢读书、写作、研究，退休后仍保持旺盛的求知欲。内心平和，以知识修身养性，晚年受人尊敬。' },
        { palace: '父母宫', desc: '父母宫文昌，主父母有学识修养，家庭教育良好。父母注重知识和文化教育，给自己打下了好的学习基础。与上司的关系偏向于师生型，上司会像老师一样指导和栽培自己。文昌在父母者早年的教育环境比较优越。' }
      ]
    },
    wenqu: {
      title: '文曲入十二宫',
      note: '文曲属阴水，为北斗文星，化气为辩才。主才艺、口才、思维敏捷、技艺技能。文曲之力如偏才之艺，主非传统的才艺和表达能力。与文昌的正式学术不同，文曲更偏重实用技能和创意表达。',
      palaces: [
        { palace: '命宫', desc: '文曲入命，主聪明机敏，多才多艺，能言善道。文曲坐命者思维活跃，善于即兴发挥，适合从事演艺、主持、辩论、营销等需要口才和表现力的行业。文曲命者学习能力强但偏重实用技能而非纯学术。为人有趣味有情调，但有时显得不够稳重。昌曲夹命者才华超群。' },
        { palace: '兄弟宫', desc: '兄弟宫文曲，主兄弟中有多才多艺之人，手足间有共同的兴趣爱好。文曲在兄弟暗示兄弟间交流多、话题丰富。与合作伙伴的关系偏向于创意和才艺的互补，适合与有才艺的人合伙创业。' },
        { palace: '夫妻宫', desc: '夫妻宫文曲，主配偶有才艺、有情趣，婚姻生活丰富多彩。配偶善于表达感情，夫妻间有良好的沟通。文曲在夫妻暗示夫妻间有共同的艺术或娱乐爱好。但文曲为才艺之星，配偶可能过于爱好玩乐，需注意节制。加煞星则可能因才艺而引起桃花纠纷。' },
        { palace: '子女宫', desc: '子女宫文曲，主子女有才艺天赋，在音乐、美术、表演等方面有特长。子女聪明但不一定适合传统的应试教育，应注重培养其才艺兴趣。文曲在子女暗示亲子间有丰富的互动和沟通，父母可以和子女一起发展兴趣爱好。' },
        { palace: '财帛宫', desc: '财帛宫文曲，主以才艺和口才赚钱。适合从事演艺、音乐、设计、咨询、销售等需要才艺和沟通能力的行业。文曲在财帛者善于抓住赚钱的机会，反应快。但财运未必稳定，有淡旺季之分。偏财运较好，有时因才艺而意外得财。' },
        { palace: '疾厄宫', desc: '疾厄宫文曲，主需注意神经系统和泌尿系统健康。文曲属水入疾厄，水主肾和膀胱。但文曲为吉星，暗示通过才艺活动（如音乐、舞蹈）可以调理身心。此人可能对养生才艺如太极、瑜伽有兴趣，以艺养身。' },
        { palace: '迁移宫', desc: '迁移宫文曲，主适合外出展示才艺或从事需要沟通交流的工作。出外时口才和表现力得到发挥，容易给人留下好印象。文曲在迁移者适合做巡回演出、外地讲座、文化交流等活动。外出时宜灵活应变，随机发挥。' },
        { palace: '交友宫', desc: '交友宫文曲，主朋友多才多艺之人，社交活动丰富多彩。朋友中有能歌善舞、口才出众者。文曲在交友者适合参加兴趣小组、才艺社团等。与朋友在一起的时光有趣味和创意，下属员工也多有才艺特长。' },
        { palace: '官禄宫', desc: '官禄宫文曲，主以才艺和口才为事业方向。适合从事演艺、广告、公关、咨询、教育培训等行业。文曲在官禄者事业发展灵活多变、不拘一格。注重工作中的创意和表达，不喜欢死板的工作方式。有演讲和培训的天赋。' },
        { palace: '田宅宫', desc: '田宅宫文曲，主家中有艺术氛围，可能设置了音乐室、画室等创意空间。家庭生活有趣味、有情调。文曲在田宅暗示住宅周边有文化娱乐设施，居住环境活泼。房产方面可能涉及与文化创意产业相关的投资。' },
        { palace: '福德宫', desc: '福德宫文曲，主精神生活丰富多彩，有广泛的兴趣爱好。晚年生活有趣，喜欢参与文化活动。文曲在福德者内心保持年轻和创意，不因年龄增长而失去趣味。喜欢音乐、艺术、旅游，享受生活的多彩多姿。' },
        { palace: '父母宫', desc: '父母宫文曲，主父母有才艺或善于沟通表达。家庭教育灵活有趣，不刻板。父母可能从事与才艺相关的工作，给子女以艺术熏陶。与上司的关系偏向于趣味相投型，上司可能欣赏自己的才艺和表达能力。' }
      ]
    }
  };

  // ═════════════════════════════════════════════════
  // 十七、六煞星入十二宫详解（新增·深度补充）
  // ═════════════════════════════════════════════════
  window.ZIWEI_KB.sixMaleficPalaces = {
    title: '六煞星入十二宫详解',
    intro: '六煞星（擎羊、陀罗、火星、铃星、地空、地劫）各入十二宫，为紫微斗数中断盘的重要参考。煞星虽凶，但并非全无是处——煞星代表竞争、动力、突破之力，关键在于有无吉星化解。《骨髓赋》云：「羊陀火铃，逢吉发财；遇凶则祸。」以下详述六煞入十二宫的具体表现。',
    qingyang: {
      title: '擎羊入十二宫',
      note: '擎羊属阳金，为北斗煞星。主竞争、是非、血光、果断、行动力。擎羊为金之刚锋，如刀刃般锐利。入命者性格刚烈果断，有开拓精神。',
      palaces: [
        { palace: '命宫', desc: '擎羊入命，主性格刚烈果敢，做事雷厉风行，但也容易冲动鲁莽。擎羊命者竞争意识强，不畏挑战，适合军警、外科医生、竞技体育等需要快速决策的职业。但需修炼心性，否则容易惹是生非。擎羊在午宫独坐为「马头带剑」威权之格。女命擎羊坐命性格过硬，婚姻宜晚。' },
        { palace: '兄弟宫', desc: '兄弟宫擎羊，主手足间有竞争关系，兄弟性格刚硬。兄弟中有人性格冲动好斗，需要互相体谅。擎羊在兄弟暗示与合作伙伴的关系有竞争因素，合伙需有明确的分工和边界。可能出现手足因利益而争执的情况。' },
        { palace: '夫妻宫', desc: '夫妻宫擎羊，主婚姻中有争执和冲突。夫妻双方性格刚硬，谁也不愿让步。擎羊在夫妻者需修炼沟通技巧，学习妥协和包容。婚姻中可能有第三者的竞争。早婚多波折，晚婚和年龄差距较大的婚姻较为稳定。加廉贞七杀则婚姻危机严重。' },
        { palace: '子女宫', desc: '子女宫擎羊，主子女性格刚烈叛逆，管教需要智慧和耐心。子女好动有闯劲，不宜过度压制。在教育方面应引导而非强迫，否则适得其反。擎羊在子女也暗示生育过程可能有波折，如难产或剖腹产。但子女也具备独立和果断的优点。' },
        { palace: '财帛宫', desc: '财帛宫擎羊，主赚钱方式大胆激进，有冒险精神。适合从事高风险高回报的行业，如投资、创业、竞技等。财运起伏大，可能快速致富也可能快速亏损。擎羊在财帛者需学会控制风险，不可一味猛冲。但擎羊也带来了果断抓住商机的能力。' },
        { palace: '疾厄宫', desc: '疾厄宫擎羊，主需防范意外伤害、手术、血光之灾。擎羊为金属刃器，在疾厄暗示容易受伤。从事工科、运动等职业需格外注意安全。但擎羊也代表「锋利」的手术刀，所以此宫也暗示外科手术的可能。定期体检和注意安全防护是关键。' },
        { palace: '迁移宫', desc: '迁移宫擎羊，主外出容易遇到竞争和冲突，旅途中需注意安全。外出时宜保持低调，避免与人发生正面冲突。擎羊在迁移暗示适合从事需要竞争力和勇气的外出工作，如业务开拓、外事谈判等。出外开车需注意交通安全。' },
        { palace: '交友宫', desc: '交友宫擎羊，主朋友中有好斗之人，交友需谨慎。容易在朋友关系中遇到竞争和背叛。下属员工中有人性格刚硬难管。擎羊在交友者不宜与朋友有金钱往来，容易因利益反目。但擎羊也代表朋友中有人行动力强，在紧急时可以依靠。' },
        { palace: '官禄宫', desc: '官禄宫擎羊，主事业上竞争激烈，需要奋力拼搏。适合从事军警、外科、竞技、创业等需要决断力和竞争力的行业。擎羊在官禄者事业发展快但也容易与人发生冲突。需注意职场中的人际关系，避免树敌过多。加吉星则竞争化为前进动力。' },
        { palace: '田宅宫', desc: '田宅宫擎羊，主家宅有纷争，家庭氛围紧张。可能有邻里纠纷或家人之间的争执。擎羊在田宅暗示房产方面可能会有法律纠纷，购房时需特别谨慎。家中利器的摆放和用水用电需注意安全。家宅周围环境可能比较喧闹。' },
        { palace: '福德宫', desc: '福德宫擎羊，主内心好强好胜，不容易满足和放松。精神上总有竞争感，难得真正的安宁。擎羊在福德者晚年仍需注意心理调节，学习放下执着。但擎羊也让人保持进取心和活力，老年不轻易服老。' },
        { palace: '父母宫', desc: '父母宫擎羊，主父母管束严厉，亲子间可能有冲突和对抗。父亲（或母亲）性格刚硬，教育方式强硬。与上司的关系紧张，上司要求严格。擎羊在父母者早年经历磨练较多，但也因此锻炼出坚韧的性格。' }
      ]
    },
    tuoluo: {
      title: '陀罗入十二宫',
      note: '陀罗属阴金，为北斗煞星。主拖延、反复、纠缠、迟滞。陀罗为金之钝锋，如钝刀割肉，缓慢而痛苦。入命者做事总差临门一脚，一生事多反复。',
      palaces: [
        { palace: '命宫', desc: '陀罗入命，主一生多磨难，做事容易反复曲折。陀罗命者不是没有能力，而是过程总是比别人曲折。好事多磨，需要极大的耐心。但陀罗也让人特别有韧性，能够坚持到最后一刻。适合从事需要重复和坚持的工作，如同科研、手工艺等。' },
        { palace: '兄弟宫', desc: '兄弟宫陀罗，主手足缘分有纠缠和拖延。兄弟间可能有长期的矛盾或纠纷，不易化解。与合作伙伴的关系黏黏糊糊，分合不定。陀罗在兄弟暗示合伙关系的结束可能非常缓慢和痛苦，宜早定退路。' },
        { palace: '夫妻宫', desc: '夫妻宫陀罗，主婚姻中有长期的不满和纠缠。夫妻感情可能拖拖拉拉，想分分不了、想好好不了。陀罗在夫妻者早婚多不如意，晚婚可部分化解。婚姻中最大的问题不是大吵大闹而是长期的冷淡和拖延。需要主动沟通打破僵局。' },
        { palace: '子女宫', desc: '子女宫陀罗，主养育子女过程比较辛苦，子女成长慢。子女可能在某方面有迟缓发育的情况，需要耐心等待。教育子女时需特别有耐心，不可急躁。陀罗在子女暗示子女与父母有长期的功课，是来磨练父母耐心的。但持之以恒的教育终有回报。' },
        { palace: '财帛宫', desc: '财帛宫陀罗，主钱财来得慢、去得也慢。赚钱需要长期坚持和积累，不适合快速致富。投资资金容易被套牢，回收期长。陀罗在财帛者宜做长线投资和储蓄，不适合短线操作。但一旦积累起来，财富也比较稳固，不易流失。' },
        { palace: '疾厄宫', desc: '疾厄宫陀罗，主疾病缠绵难愈，多为慢性疾病。疾病的发展过程缓慢但持续，需长期调养。陀罗在疾厄暗示可能有一些迁延不愈的病症，需要耐心治疗。老年人尤其需注意慢性病的调理。定期复查和坚持治疗是关键。' },
        { palace: '迁移宫', desc: '迁移宫陀罗，主出外容易遇到拖延和阻碍。出差或旅行常常遇到各种意想不到的延误。不适合频繁出外，宜守不宜攻。陀罗在迁移暗示在外地发展会比较缓慢，需要比本地更长的时间来扎根。出外宜做长期规划而非短期尝试。' },
        { palace: '交友宫', desc: '交友宫陀罗，主朋友关系中容易有不快的纠缠。可能有长期的友情因为某些事变得尴尬或纠葛。下属效率低，做事拖沓。陀罗在交友者社交圈小但持久，朋友关系以长久为主，不宜频繁更换朋友。' },
        { palace: '官禄宫', desc: '官禄宫陀罗，主事业进展缓慢，晋升和跳槽都比较困难。适合做稳定、重复性高、需要耐心的工作。陀罗在官禄者不宜频繁跳槽，在一个单位长期坚持反有回报。事业发展如老牛拉车，慢但稳。加吉星则厚积薄发。' },
        { palace: '田宅宫', desc: '田宅宫陀罗，主家宅有小麻烦不断，如漏水、邻里矛盾等。房产交易过程容易遇到拖延和障碍，买卖周期长。陀罗在田宅暗示家庭中有一些长期存在的问题，如长辈健康等，需要持续关注。但陀罗也意味着家宅稳固、不易搬迁。' },
        { palace: '福德宫', desc: '福德宫陀罗，主内心容易纠结、放不下。精神上常常自我折磨，为小事反复思量。陀罗在福德者晚年需学习放下和豁达，否则内心难得安宁。但陀罗也让人有深度，善于反思和总结，精神世界丰富而复杂。' },
        { palace: '父母宫', desc: '父母宫陀罗，主父母之间有长期的矛盾或父母身体长期不佳。与父母的关系有纠缠，既爱又怨。与上司的关系进展缓慢，需要较长时间才能获得信任。陀罗在父母暗示早年成长环境中有一些长期存在的困扰。' }
      ]
    },
    huoxing: {
      title: '火星入十二宫',
      note: '火星属阳火，为南斗煞星。主冲动、急躁、突发、暴烈。火星如烈火燎原，来得快去得也快。入命者爆发力强、快人快语，但做事不耐久。',
      palaces: [
        { palace: '命宫', desc: '火星入命，主性格快人快语、雷厉风行、爆发力强。火星座命者性子急、藏不住话，有正义感。适合从事需要快速反应的工作如消防、急诊、新闻等。火星入命也暗示相貌偏红润或容易脸红。做事有冲劲但缺乏耐心，容易三分钟热度。加贪狼成火贪格主暴发。' },
        { palace: '兄弟宫', desc: '兄弟宫火星，主兄弟性格急躁易怒，手足间容易因小事发生争执但来得快去得也快。火星在兄弟暗示与合作伙伴的合作节奏快，关系热得快冷得也快。合伙宜快进快出型项目，不宜长期深度合作。' },
        { palace: '夫妻宫', desc: '夫妻宫火星，主婚姻中容易爆发激烈争吵，但吵完就好的类型。夫妻感情热烈但容易因冲动做出伤害对方的事。火星在夫妻者需控制情绪，学会冷静沟通。婚姻热情度高但稳定性差，需要双方共同努力维护。加贪狼则感情来得快去得也快。' },
        { palace: '子女宫', desc: '子女宫火星，主子女性格急躁好动，容易闯祸。子女精力旺盛，需要释放能量的渠道，如体育运动。教育子女时不宜正面冲突，宜引导而非压制。火星在子女暗示生育过程可能较快（急产），子女小时候容易发烧感冒需注意。' },
        { palace: '财帛宫', desc: '财帛宫火星，主财运来得快但也可能去得快。有快速致富的机会但也容易快速亏损。适合做短线投资和快消品行业。火星在财帛者把握商机的速度是一大优势，但冲动消费也是大问题。需培养财务自律。加贪狼成火贪格主暴发暴富。' },
        { palace: '疾厄宫', desc: '疾厄宫火星，主容易患急性疾病，如感冒发烧、急性炎症。疾病来得快去得也快，但急性发作时可能比较猛烈。火星在疾厄暗示需注意心脑血管和皮肤问题。平时应注意防火安全，避免烫伤烧伤。情绪管理对健康影响较大。' },
        { palace: '迁移宫', desc: '迁移宫火星，主外出容易遇到突发事件和意外变数。旅行中可能有刺激的冒险或突发状况。火星在迁移者不适合平静的旅行，喜欢冒险和刺激。出外工作时宜快但不草率，注意交通和人身安全。适合突发性、应急性的外出工作。' },
        { palace: '交友宫', desc: '交友宫火星，主朋友多急性子之人，社交活动热烈但朋友关系容易来来去去。朋友帮得快散得也快。火星在交友者适合在快节奏的社交圈中活动，不宜对朋友期望过高。下属有力但管理难度大，需以激励代替压制。' },
        { palace: '官禄宫', desc: '官禄宫火星，主事业上常有突发机会但也伴有风险。适合快节奏的行业如互联网、新媒体、时尚等。火星在官禄者创业爆发力强但守成能力弱，宜有团队互补。事业发展有「不鸣则已一鸣惊人」的特点。突发事件处理能力强。' },
        { palace: '田宅宫', desc: '田宅宫火星，主家宅需注意防火安全。家庭氛围热烈但也容易因为小事爆发争吵。可能有搬家频繁的现象。火星在田宅暗示住宅周围可能有热闹的商业区或交通繁忙。房产投资方面宜快进快出，不宜长期持有。' },
        { palace: '福德宫', desc: '福德宫火星，主内心容易焦躁不安，难得清静。精神上需要寻找释放压力的渠道，如运动、旅行、刺激的活动。火星在福德者晚年仍活跃好动，不喜欢安静退休生活。但需注意急脾气对身体的影响，学习慢下来。' },
        { palace: '父母宫', desc: '父母宫火星，主父母（尤其是父亲）脾气急躁，家庭教育有火爆的一面。与父母之间容易有短暂的冲突和冷战。与上司的关系如急火爆炒，需要快速建立信任。火星在父母暗示童年家庭氛围比较热闹甚至是纷闹的。' }
      ]
    },
    lingxing: {
      title: '铃星入十二宫',
      note: '铃星属阴火，为南斗煞星。主阴险、心机、暗斗、暗中算计。铃星如暗火闷烧，不张扬但持续。入命者心机深沉，城府较深，善于长远谋划。',
      palaces: [
        { palace: '命宫', desc: '铃星入命，主心机深沉、城府较深，善于长远谋划。铃星命者不轻易表露真实想法，喜怒不形于色。适合从事需要谋略和隐忍的工作，如战略规划、情报分析、暗访调查等。铃星在命暗示为人有持久力，能忍常人所不能忍。加贪狼成铃贪格亦主暴发。' },
        { palace: '兄弟宫', desc: '兄弟宫铃星，主兄弟间有心机和暗中的较量。手足关系表面平和但暗中有比较和竞争。铃星在兄弟暗示与合作伙伴的关系需要防暗算，合伙前应充分了解对方底细。兄弟中有人心思深沉不易看透。' },
        { palace: '夫妻宫', desc: '夫妻宫铃星，主婚姻中有暗中的不满和长期积累的矛盾。夫妻双方可能有秘密或隐瞒，缺乏真正的坦诚。铃星在夫妻者婚姻中的问题不爆发则已，一爆发就是长期的积怨。应学习坦诚沟通，不要等到积重难返。加贪狼则暗中桃花不断。' },
        { palace: '子女宫', desc: '子女宫铃星，主子女心思深沉，不易与父母坦诚交流。子女可能早熟，有自己的小秘密。教育子女时应营造开放宽松的家庭氛围，鼓励子女说出心里话。铃星在子女暗示子女在某些方面需要长期的培养和耐心引导。' },
        { palace: '财帛宫', desc: '财帛宫铃星，主财运有暗中的机会但也需防暗中的损失。适合做需要精密度和长期布局的投资。铃星在财帛者善于发现别人看不到的商机，但也可能因过于隐秘而错失良机。理财方面适合低调长期规划，不宜炫富。加贪狼成铃贪格主暴发。' },
        { palace: '疾厄宫', desc: '疾厄宫铃星，主疾病暗中发展、不易被发现。需注意定期体检，尤其关注慢性疾病和隐疾。铃星在疾厄暗示心理问题也可能暗中累积，如抑郁、焦虑等。应重视心理健康，及时疏导情绪。中医调理和养生功法有助于改善体质。' },
        { palace: '迁移宫', desc: '迁移宫铃星，主外出时需防暗中的算计和陷阱。出外时应保持警惕，不要轻信他人。铃星在迁移暗示适合从事需要暗中操作的外出工作。在外地发展不宜过于高调，低调潜伏反有收获。旅途中需注意财物安全。' },
        { palace: '交友宫', desc: '交友宫铃星，主朋友中有心思深沉之人，交友需防暗算。朋友中可能有口蜜腹剑之人，交往时需留个心眼。铃星在交友者社交圈虽不大但关系持久，擅长与少数人保持深度关系。下属中有人善于察言观色，管理时需公正透明。' },
        { palace: '官禄宫', desc: '官禄宫铃星，主事业上需防暗中的竞争对手和职场陷阱。适合做需要深度规划和长期布局的工作。铃星在官禄者擅长做战略和幕后工作，不喜抛头露面。事业发展慢但稳，属于厚积薄发型。在职场中应注意建立公开透明的形象。' },
        { palace: '田宅宫', desc: '田宅宫铃星，主家宅中有暗藏的问题，如隐蔽的水电问题、风水暗煞等。家庭中有长期未解决的矛盾或秘密。铃星在田宅暗示购房时需仔细检查房屋的隐藏问题，避免买到有暗病的房子。家中可能有长期存放不用的杂物。' },
        { palace: '福德宫', desc: '福德宫铃星，主内心阴暗面较多，容易多想和钻牛角尖。精神上需要寻找光明和出口，否则容易陷入长期的消极情绪。铃星在福德者晚年需主动参与社交和积极的活动，避免将自己封闭起来。但铃星也赋予深刻的自省能力。' },
        { palace: '父母宫', desc: '父母宫铃星，主父母间有暗中的问题或家庭有隐藏的故事。父母可能对自己有所隐瞒。与上司的关系表面和谐但暗中有较量。铃星在父母暗示童年家庭环境中有一些不便明说的事情，影响了自己的性格形成。' }
      ]
    },
    dikong: {
      title: '地空入十二宫',
      note: '地空为空亡星，属阴火。主虚花、落空、损耗、理想主义、精神追求。地空如无底洞，钱财入此如投虚空。入命者思想超脱，不切实际但富有创意。',
      palaces: [
        { palace: '命宫', desc: '地空入命，主理想主义者，思想超前，天马行空。地空命者不适合太现实的行业，在学术、科研、哲学、艺术等精神领域更有建树。钱财观念淡薄，不易积累财富但精神世界丰富。地空坐命者一生需解决理想与现实的矛盾。从事精神性工作则可将空性转化为创造力。' },
        { palace: '兄弟宫', desc: '兄弟宫地空，主手足缘分浅薄，兄弟姐妹聚少离多。与兄弟关系中有一种空幻感，可能兄弟不在身边或交流较少。地空在兄弟暗示与合作伙伴的关系容易落空，合作计划可能无法落实。合作前需多方确认对方的诚意和能力。' },
        { palace: '夫妻宫', desc: '夫妻宫地空，主婚姻中有空虚感和不踏实感。夫妻间可能有精神层面的不契合，感觉对方不是真正的灵魂伴侣。地空在夫妻者需要面对婚姻中理想化的期待与现实的落差。婚姻容易因为精神上的不满足而出问题。需要降低期待，脚踏实地经营。' },
        { palace: '子女宫', desc: '子女宫地空，主子女缘分较浅，可能有生育方面的困难。若已有子女，则子女可能性格独立、早熟或与父母聚少离多。地空在子女暗示亲子关系中需放下过高的期望，接受子女的真实样貌。子女可能在精神层面超越父母。' },
        { palace: '财帛宫', desc: '财帛宫地空为较差配置之一。主钱财如流水过手，左手进右手出。赚钱辛苦但存不住钱，常有意外支出。地空在财帛者不适合从事需要资金积累的行业，适合赚快钱或以创意和思想换钱。理财方面宜简单直接，不宜复杂投资。' },
        { palace: '疾厄宫', desc: '疾厄宫地空，主体质偏弱，恢复力差。疾病可能有「虚症」特点，如气血不足、肾虚等。地空在疾厄暗示健康问题可能与其心理状态有关，内心空虚可能导致身体问题。适合练习太极、气功等调理气息的养生功法。' },
        { palace: '迁移宫', desc: '迁移宫地空，主外出发展容易落空，不如在本地。外地机会看似很多但实际收获少。地空在迁移暗示出外旅行时可能遇到计划落空的情况，如航班取消、行程改变等。出外时宜降低期待，顺其自然。不适合移民。' },
        { palace: '交友宫', desc: '交友宫地空，主朋友多变，朋友关系不稳定。朋友中的承诺容易落空，不宜对朋友期望过高。地空在交友者社交圈可能比较松散，朋友来去匆匆。下属员工流动性大，难以建立稳固的团队。独立工作比依赖团队更有利。' },
        { palace: '官禄宫', desc: '官禄宫地空，主事业上容易有理想落空之感。事业方向可能多变，每次看似好的机会最终都不如预期。地空在官禄者适合从事学术研究、哲学、艺术、公益等精神性工作，不以物质回报为主要目标。创意行业反而能化空为有。' },
        { palace: '田宅宫', desc: '田宅宫地空，主家宅运不好，可能经常搬家或居无定所。房产投资容易亏损或遇到烂尾。地空在田宅暗示对家的概念比较淡，不执着于拥有房产。适合租住或简约的生活方式。家中可能比较空旷，不宜摆放过多物品。' },
        { palace: '福德宫', desc: '福德宫地空，主精神上有空灵感，对物质需求低。喜欢哲学、宗教、灵性探索。地空在福德者晚年对世间的执着较少，有种超脱的气质。但若煞星过多，可能变得消极避世。适合以精神修养充实晚年生活。' },
        { palace: '父母宫', desc: '父母宫地空，主与父母缘分较浅，可能父母早逝或长期不在身边。父母给予的物质帮助较少，但可能留下精神财富。与上司的关系不稳固，上司的承诺容易落空。地空在父母者需及早学会独立，不依赖他人。' }
      ]
    },
    dijie: {
      title: '地劫入十二宫',
      note: '地劫为劫煞星，属阳火。主破财、损失、变动、波折。地劫如黑洞，钱财入此即被劫走。入命者多有意外破财，一生有多次大的损失变动。',
      palaces: [
        { palace: '命宫', desc: '地劫入命，主一生有多次意外的破财和损失，钱财不易留住。地劫命者人生波折多，经历丰富。但地劫也赋予人坚韧不拔的性格——经历过多次打击后变得更强大。适合从事需要冒险和承受能力的行业，不适合过于安稳的职业。一生如过关斩将。' },
        { palace: '兄弟宫', desc: '兄弟宫地劫，主手足关系有大的变故，可能因为钱财问题而反目。兄弟中有人可能会拖累自己或自己需要为兄弟付出较多。地劫在兄弟暗示合作伙伴可能会造成自己的财务损失，合伙需特别注意财务透明。' },
        { palace: '夫妻宫', desc: '夫妻宫地劫，主婚姻可能经历重大的考验和变故。夫妻间可能因为钱财问题产生矛盾。地劫在夫妻者婚姻中可能有突然的变故，如配偶遇意外或经济困难。婚姻需要双方共同面对风浪，患难见真情。加廉贞破军则婚姻有严重危机。' },
        { palace: '子女宫', desc: '子女宫地劫，主为子女花费巨大，子女可能给自己带来经济负担。子女成长过程中可能有突发的大额支出，如医疗、教育等。地劫在子女暗示生育过程可能有意外情况。子女成年后可能经济独立较晚，需要父母持续的财务支持。' },
        { palace: '财帛宫', desc: '财帛宫地劫为最差的配置之一。主钱财有突然的大的损失，如投资失败、被骗、被盗等。赚钱能力有，但守财能力极差。地劫在财帛者理财需格外谨慎，宜将资金分散投资，避免把所有鸡蛋放在一个篮子里。建议定期将利润转为固定资产。' },
        { palace: '疾厄宫', desc: '疾厄宫地劫，主健康方面可能有突然的重大的问题。需特别防范意外伤害和突发疾病。地劫在疾厄暗示身体的某个系统可能比较脆弱，容易被突然击垮。定期体检不能松懈。同时注意安全，避免高风险运动和工作。' },
        { palace: '迁移宫', desc: '迁移宫地劫，主外出容易遇到意外和损失。旅途中可能发生财物被盗、证件丢失等情况。地劫在迁移者出外时需格外小心，购买旅行保险、备份重要文件等。在外面遇到困难时不宜慌乱，冷静应对。不适合频繁的外出和冒险旅行。' },
        { palace: '交友宫', desc: '交友宫地劫，主朋友中可能有损友，容易被朋友坑害造成损失。交友需格外谨慎，金钱方面与朋友分清界限。地劫在交友者社交圈需要精减，朋友贵精不贵多。下属中可能有人会做损害公司利益的事，管理需严格。' },
        { palace: '官禄宫', desc: '官禄宫地劫，主事业发展中可能遇到重大的挫折和损失。事业可能大起大落，有破产或失业的风险。地劫在官禄者不适合安于现状，需要有冒险精神和危机意识。但地劫也意味着事业上每一次「劫」后都有重建的机会和提升。' },
        { palace: '田宅宫', desc: '田宅宫地劫，主家宅有大的变动，如火灾、水灾、拆迁等。房产投资容易亏损或遇到产权纠纷。地劫在田宅暗示不宜把所有积蓄投在房产上。家中需注意安全隐患。但地劫也暗示经历变动的家庭可能更加团结和坚强。' },
        { palace: '福德宫', desc: '福德宫地劫，主晚运可能经历重大的挫折和损失。晚年生活需有充足的准备和保险。地劫在福德者不宜把所有希望寄托在养老制度或子女身上，应有自己的储备。但地劫也让人在经历风雨后更懂得珍惜和感恩，晚年的智慧境界较高。' },
        { palace: '父母宫', desc: '父母宫地劫，主父母可能经历重大的财务困难或变故，无法给予自己足够的支持。地劫在父母者早年可能经历家庭的重大变故，如破产、失去父母等。与上司的关系不稳定，上司可能突然离职或公司发生变动。需要自我独立。' }
      ]
    }
  };

  // ═════════════════════════════════════════════════
  // 十八、双星组合详解（新增·深度补充）
  // ═════════════════════════════════════════════════
  window.ZIWEI_KB.doubleStarCombos = {
    title: '双星组合详解',
    intro: '双星同宫是紫微斗数中非常重要的组合，两颗主星同在一宫产生化合反应，形成了独特的格局和人生轨迹。《太微赋》曰：「双星并耀，吉凶互现，需辨其庙陷强弱。」以下详列20组最重要的双星组合及其在关键宫位的解读。',
    combos: [
      { name: '紫微天府', palaces: '紫微+天府同宫在寅申',
        desc: '紫府同宫为紫微斗数中第一大吉格。紫微为帝星主贵，天府为库星主富，二星同宫则富贵双全。此组合之人格局宏大，性格外刚内稳，做事既有魄力又有章法。',
        minggong: '紫府入命者一生安稳富足，格局宏大，有领导才能和包容力。适合从政、管理、金融等需要权钱双收的行业。但过于安稳也可能缺乏突破力。',
        caibo: '财帛宫紫府为最佳配置之一，主钱财有权有势亦有库。赚钱能力和社会地位相匹配，财富积累稳健。善于利用权力和资源换取财富。',
        shiye: '紫府在官禄宫者事业有权威且稳定，是典型的大企业高管或政府高官的命格。事业上升路径清晰，有贵人相助，适合大型组织的管理层。',
        fuqi: '夫妻宫紫府者配偶既有社会地位也有经济实力，婚姻门当户对。但夫妻关系偏「政治婚姻」型，感情可能不如利益契合来得重要。' },
      { name: '紫微七杀', palaces: '紫微+七杀同宫在巳亥',
        desc: '紫杀同宫为威权之格。紫微之尊与七杀之勇结合，如帝王身边的猛将。此组合之人性格刚烈果敢、权威开拓，适合创业、从军、从政等需要魄力的领域。',
        minggong: '紫杀入命者敢于开拓，有领袖气质和决断力。但性格过于刚硬，需要左辅右弼来调和。一生大起大落，不宜安逸，越有挑战越精彩。',
        caibo: '紫杀在财帛者赚钱方式大胆，敢做高风险高回报的投资。财运起伏大，可能富可敌国也可能一朝返贫。需要专业的财务团队辅助。',
        shiye: '紫杀在官禄为开拓型事业运。适合创业当老板或做高管，适合军警、地产、建筑等需要强执行力的行业。事业有开疆拓土之势。',
        fuqi: '紫杀在夫妻者婚姻中有激烈的权力斗争。双方性格都刚硬，需要磨合。婚姻进展快但风险大，适合晚婚。配偶也是强势人物。' },
      { name: '紫微破军', palaces: '紫微+破军同宫在丑未',
        desc: '紫破同宫主动荡不安。紫微之尊与破军之耗结合，如帝王身边出了个不安分的改革者。此组合之人一生充满变故，有不断打破重建的倾向。适合变革、创新类工作。',
        minggong: '紫破入命者敢作敢为，不按常理出牌。一生变化极大，可能多次转换人生方向。性格中有不安分的因子，适合创业和创新。但一生不稳定是最大挑战。',
        caibo: '紫破在财帛者钱财大进大出如洪水过境。善于赚大钱但也善于花大钱。需要有强大的财务管理系统。暴富暴贫交替的命格。',
        shiye: '紫破在官禄者事业多变，不适合稳定工作。适合创业者和改革者，在动荡中寻找机会。事业如同冲浪，每次浪来都有新的可能。',
        fuqi: '紫破在夫妻者婚姻多变不稳定。夫妻关系如过山车，高时极高低时极低。早婚不太适合，晚婚或有多次婚姻经历后更懂得珍惜。' },
      { name: '紫微贪狼', palaces: '紫微+贪狼同宫在卯酉',
        desc: '紫贪同宫即「桃花犯主」格。紫微之尊贵与贪狼之欲望结合，如同帝王沉迷美色。此组合之人才华横溢但需克制欲望，否则贵人身份被欲望侵蚀。',
        minggong: '紫贪入命者多才多艺，有领袖魅力，但桃花极重。才华和欲望并存，需自我约束。适合演艺、艺术、公关等需要魅力的行业。',
        caibo: '紫贪在财帛者财源广且善于交际应酬赚钱。偏财运强，适合娱乐、时尚、奢侈品等行业。但花钱也大手大脚，需要节制。',
        shiye: '紫贪在官禄者事业多有贵人提携但因桃花或人际问题而有波折。适合需要社交能力的行业。事业上容易因男女关系而受影响，需公私分明。',
        fuqi: '紫贪在夫妻者配偶魅力大但桃花极重，婚姻多有第三者困扰。婚前情史丰富，婚后需格外经营。配偶可能是众人瞩目的对象。' },
      { name: '天机太阴', palaces: '天机+太阴同宫在寅申',
        desc: '机阴同宫为「机月」组合的基础。天机之智与太阴之柔结合，聪明而细腻。此组合之人善于策划和细节把控，适合策划、财务、资讯类工作。',
        minggong: '机阴入命者心思缜密，善于分析和规划。性格偏内向细腻，做事有条理。机关算尽但有时过于多虑而错失行动时机。加天同天梁则成机月同梁格。',
        caibo: '机阴在财帛者以智慧和耐心赚钱。善于理财规划，能精打细算。适合做会计、投资顾问、精算师等需要精密计算的职业。',
        shiye: '机阴在官禄者适合脑力劳动和精细化工作。事业上善于策略，适合做策划、咨询、研究。但可能过于谨慎而缺乏突破力。',
        fuqi: '机阴在夫妻者婚姻以理性和细腻的沟通为主。夫妻间互相理解，善于照顾对方的情绪。但有时过于分析关系反而少了感性。' },
      { name: '天机巨门', palaces: '天机+巨门同宫在卯酉',
        desc: '巨机同宫为「巨机同宫格」。天机之智与巨门之口结合，口才与智慧并存。此组合之人善于辩论分析，但也容易惹口舌是非。适合律师、咨询、媒体等行业。',
        minggong: '巨机入命者能言善辩，思维敏捷，善于发现问题的关键。但说话过于犀利容易得罪人。适合做律师、评论家、谈判专家。为人精明但人缘需注意维护。',
        caibo: '巨机在财帛者以口才和信息赚钱。适合中介、咨询、金融分析等需要信息和沟通的行业。财源来自认知差和信息差。',
        shiye: '巨机在官禄者事业上以口为业，善于辩论和谈判。适合法律、新闻、公关等行业。但职场中需注意避免因言惹祸，说话留三分。',
        fuqi: '巨机在夫妻者婚姻中口角争执多。夫妻双方都善于言辞，吵起来旗鼓相当。需学习少说多听，否则容易因话伤感情。' },
      { name: '天机天梁', palaces: '天机+天梁同宫在辰戌',
        desc: '机梁同宫为「机梁善谈格」。天机之智与天梁之慈结合，既是智谋又是善士。此组合之人有军师之才，善谈兵机，解厄救困。',
        minggong: '机梁入命者智谋过人且有长者之风，喜欢帮助他人。适合做军师、顾问、医疗工作者。性格中有「老大」的气质，好管闲事但确实能解决问题。',
        caibo: '机梁在财帛者财运来自智慧和助人。适合做教育培训、医疗保健、咨询服务等既能赚钱又能帮助他人的行业。不以利为先，反而财运不错。',
        shiye: '机梁在