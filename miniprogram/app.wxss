/* app.wxss — 命理宝鉴全局样式 */

/* 色彩变量 */
page {
  --bg-primary: #1a1a2e;
  --bg-card: #16213e;
  --bg-card-hover: #1e2a4a;
  --text-primary: #f0f0f0;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --gold: #e6c86e;
  --gold-dark: #c4a84e;
  --green: #4ade80;
  --red: #f87171;
  --blue: #60a5fa;
  --purple: #a78bfa;
  --border: #2a3a5c;

  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 16rpx;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #e6c86e 0%, #c4a84e 100%);
  color: #1a1a2e;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-outline {
  background: transparent;
  color: var(--gold);
  border: 2rpx solid var(--gold);
  border-radius: 12rpx;
  padding: 18rpx 38rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-gold {
  background: rgba(230, 200, 110, 0.15);
  color: var(--gold);
}

.tag-green {
  background: rgba(74, 222, 128, 0.15);
  color: var(--green);
}

.tag-red {
  background: rgba(248, 113, 113, 0.15);
  color: var(--red);
}

/* 输入框 */
.input {
  background: var(--bg-card-hover);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-muted);
  font-size: 28rpx;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-secondary);
}
