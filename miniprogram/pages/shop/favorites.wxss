.page-favorites { padding: 20rpx; min-height: 100vh; }
.loading { text-align: center; padding: 60rpx; color: #94a3b8; font-size: 28rpx; }
.fav-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.fav-card { background: #16213e; border-radius: 16rpx; padding: 20rpx; position: relative; }
.fav-img { width: 100%; height: 180rpx; background: #1a1a2e; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 56rpx; margin-bottom: 16rpx; }
.fav-info { }
.fav-name { font-size: 26rpx; color: #f0f0f0; font-weight: 500; margin-bottom: 8rpx; }
.fav-desc { font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx; line-height: 1.4; }
.fav-price { font-size: 30rpx; color: #e6c86e; font-weight: 700; }
.fav-remove { position: absolute; top: 16rpx; right: 16rpx; font-size: 20rpx; color: #94a3b8; background: rgba(0,0,0,.4); padding: 6rpx 16rpx; border-radius: 20rpx; }
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 70vh; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #94a3b8; }
