/* pages/shop/shop.wxss */
.page-shop { padding-bottom: 40rpx; }

.category-bar {
  display: flex;
  padding: 20rpx 20rpx;
  overflow-x: auto;
  white-space: nowrap;
  background: #16213e;
  position: sticky;
  top: 0;
  z-index: 10;
}

.cat-item {
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #94a3b8;
  background: #1a1a2e;
}

.cat-item.active {
  color: #e6c86e;
  background: rgba(230, 200, 110, 0.15);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

.product-card {
  width: 48%;
  margin: 0 1% 20rpx;
  background: #16213e;
  border-radius: 16rpx;
  overflow: hidden;
}

.product-img-placeholder {
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  background: linear-gradient(135deg, #0f3460, #16213e);
}

.product-info { padding: 20rpx; }

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f0f0f0;
}

.product-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
  line-height: 1.4;
}

.product-price {
  font-size: 34rpx;
  color: #e6c86e;
  font-weight: 700;
  margin-top: 10rpx;
}
