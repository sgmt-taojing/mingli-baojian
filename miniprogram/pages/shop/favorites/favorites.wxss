/* favorites.wxss */
.page {
  min-height: 100vh;
  background: #1a1a2e;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 280rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #e6c86e;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #e6c86e;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 50rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #e6c86e, #d4af37);
  color: #1a1a2e;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 80rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-btn::after {
  border: none;
}

/* 收藏网格 */
.fav-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 6rpx;
}

.fav-card {
  width: 340rpx;
  background: #16213e;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

/* 商品图片 */
.fav-cover {
  width: 100%;
  height: 240rpx;
  overflow: hidden;
  background: #0f1629;
}

.cover-img {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.fav-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.fav-title {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.fav-desc {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  flex: 1;
}

.fav-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fav-price {
  font-size: 32rpx;
  color: #e6c86e;
  font-weight: 600;
}

.fav-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  background: rgba(230, 200, 110, 0.15);
}

.cart-icon .icon-text {
  color: #e6c86e;
  font-size: 28rpx;
}

.remove-icon {
  background: rgba(148, 163, 184, 0.15);
}

.remove-icon .icon-text {
  color: #94a3b8;
  font-size: 36rpx;
  line-height: 1;
}

/* 响应式 - 大屏 */
@media (min-width: 600px) {
  .fav-card {
    width: 280rpx;
  }
}

/* 响应式 - 小屏 */
@media (max-width: 350px) {
  .fav-card {
    width: 100%;
  }
}
