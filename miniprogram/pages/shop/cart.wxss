.page-cart { padding: 20rpx; min-height: 100vh; }
.loading { text-align: center; padding: 60rpx; color: #94a3b8; font-size: 28rpx; }
.cart-list { padding-bottom: 120rpx; }
.cart-item { display: flex; align-items: center; gap: 16rpx; background: #16213e; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.item-check { flex-shrink: 0; }
.checkbox { width: 40rpx; height: 40rpx; border: 3rpx solid #475569; border-radius: 50%; }
.checkbox.checked { background: #e6c86e; border-color: #e6c86e; }
.item-img { width: 120rpx; height: 120rpx; background: #1a1a2e; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; flex-shrink: 0; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #f0f0f0; margin-bottom: 8rpx; }
.item-price { font-size: 32rpx; color: #e6c86e; font-weight: 600; margin-bottom: 12rpx; }
.item-qty { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border: 2rpx solid #475569; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #94a3b8; }
.qty-num { font-size: 28rpx; color: #f0f0f0; min-width: 48rpx; text-align: center; }
.item-remove { font-size: 24rpx; color: #ef4444; flex-shrink: 0; }
.cart-footer { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; gap: 20rpx; background: #16213e; padding: 20rpx 30rpx; border-top: 2rpx solid #2a3a5c; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }
.footer-check { display: flex; align-items: center; gap: 12rpx; font-size: 26rpx; color: #94a3b8; }
.footer-total { flex: 1; text-align: right; }
.total-label { font-size: 26rpx; color: #94a3b8; }
.total-price { font-size: 36rpx; color: #e6c86e; font-weight: 700; }
.footer-checkout { background: #e6c86e; color: #1a1a2e; font-size: 28rpx; font-weight: 600; padding: 16rpx 32rpx; border-radius: 40rpx; }
.footer-checkout.disabled { background: #475569; color: #94a3b8; }
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 70vh; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #94a3b8; margin-bottom: 32rpx; }
.empty-btn { background: #e6c86e; color: #1a1a2e; padding: 16rpx 48rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 500; }
