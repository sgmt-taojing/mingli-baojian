/* orders.wxss */
.page {
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #16213e;
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 0 10rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  color: #94a3b8;
  font-size: 28rpx;
  transition: color 0.2s;
}

.tab-item.active .tab-text {
  color: #e6c86e;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #e6c86e, #d4af37);
  border-radius: 3rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 280rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #e6c86e;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #94a3b8;
  margin-bottom: 50rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #e6c86e, #d4af37);
  color: #1a1a2e;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 80rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-btn::after {
  border: none;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
}

.order-card {
  background: #16213e;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(230, 200, 110, 0.1);
}

.order-no {
  font-size: 24rpx;
  color: #94a3b8;
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
}

.status-pending {
  color: #e6c86e;
}

.status-paid {
  color: #4ade80;
}

.status-shipped {
  color: #60a5fa;
}

.status-completed {
  color: #94a3b8;
}

/* 订单内容 */
.order-body {
  display: flex;
  padding: 24rpx;
}

.order-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #0f1629;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.order-title {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.order-qty {
  font-size: 24rpx;
  color: #94a3b8;
}

.order-price {
  font-size: 34rpx;
  color: #e6c86e;
  font-weight: 600;
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx 24rpx;
  gap: 20rpx;
}

.action-btn {
  padding: 14rpx 36rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e6c86e, #d4af37);
  color: #1a1a2e;
}

.action-btn.secondary {
  background: transparent;
  color: #94a3b8;
  border: 1rpx solid #94a3b8;
}
