<!-- orders.wxml -->
<view class="page">
  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === item.type ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="type"
      data-type="{{item.type}}"
      bindtap="switchTab"
    >
      <text class="tab-text">{{item.name}}</text>
      <view class="tab-line" wx:if="{{currentTab === item.type}}"></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">&#xe6c8;</view>
    <view class="empty-text">暂无相关订单</view>
    <button class="empty-btn" bindtap="goShopping">去逛逛</button>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:else>
    <view class="order-card" wx:for="{{orderList}}" wx:key="id" data-id="{{item.id}}" bindtap="viewDetail">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-no">订单号：{{item.id}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>

      <!-- 订单内容 -->
      <view class="order-body">
        <view class="order-cover">
          <image src="{{item.cover || '/images/placeholder.png'}}" mode="aspectFill" class="cover-img"></image>
        </view>
        <view class="order-info">
          <view class="order-title">{{item.title}}</view>
          <view class="order-meta">
            <text class="order-time">{{item.createTime}}</text>
            <text class="order-qty">×{{item.num}}</text>
          </view>
          <view class="order-price">¥{{item.price * item.num}}</view>
        </view>
      </view>

      <!-- 订单操作 -->
      <view class="order-actions">
        <view
          class="action-btn secondary"
          wx:if="{{item.status === 'pending'}}"
          data-id="{{item.id}}"
          catchtap="cancelOrder"
        >
          取消订单
        </view>
        <view
          class="action-btn primary"
          wx:if="{{item.status === 'pending'}}"
          data-id="{{item.id}}"
          catchtap="goPay"
        >
          去支付
        </view>
        <view
          class="action-btn primary"
          wx:if="{{item.status === 'shipped'}}"
          data-id="{{item.id}}"
          catchtap="confirmReceive"
        >
          确认收货
        </view>
        <view
          class="action-btn secondary"
          wx:if="{{item.status === 'paid' || item.status === 'completed'}}"
          data-id="{{item.id}}"
          catchtap="viewDetail"
        >
          查看详情
        </view>
      </view>
    </view>
  </view>
</view>
