.page-orders { padding: 20rpx; min-height: 100vh; }
.tab-bar { display: flex; gap: 12rpx; padding: 16rpx 0; margin-bottom: 16rpx; }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #94a3b8; border-radius: 12rpx; background: #16213e; }
.tab-item.active { background: #e6c86e; color: #1a1a2e; font-weight: 600; }
.loading { text-align: center; padding: 60rpx; color: #94a3b8; font-size: 28rpx; }
.order-list { padding-bottom: 40rpx; }
.order-card { background: #16213e; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; padding-bottom: 16rpx; border-bottom: 2rpx solid #2a3a5c; }
.order-id { font-size: 24rpx; color: #94a3b8; font-family: monospace; }
.order-status { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
.status-pending { background: rgba(245,158,11,.2); color: #f59e0b; }
.status-paid { background: rgba(34,197,94,.2); color: #4ade80; }
.status-shipped { background: rgba(59,130,246,.2); color: #60a5fa; }
.order-items { margin-bottom: 16rpx; }
.order-item-row { display: flex; align-items: center; gap: 12rpx; padding: 8rpx 0; }
.prod-name { flex: 1; font-size: 26rpx; color: #f0f0f0; }
.prod-qty { font-size: 24rpx; color: #94a3b8; }
.prod-price { font-size: 26rpx; color: #e6c86e; }
.order-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 16rpx; border-top: 2rpx solid #2a3a5c; }
.order-time { font-size: 22rpx; color: #64748b; }
.order-total { display: flex; align-items: center; }
.total-label { font-size: 24rpx; color: #94a3b8; }
.total-amount { font-size: 32rpx; color: #e6c86e; font-weight: 700; }
.order-actions { display: flex; justify-content: flex-end; gap: 16rpx; margin-top: 16rpx; }
.action-btn { padding: 12rpx 32rpx; border-radius: 30rpx; font-size: 26rpx; font-weight: 500; }
.pay-btn { background: #e6c86e; color: #1a1a2e; }
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 70vh; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #94a3b8; }
