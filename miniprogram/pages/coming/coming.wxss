.coming-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
}
.coming-icon { font-size: 100rpx; margin-bottom: 30rpx; }
.coming-title { font-size: 36rpx; font-weight: 600; color: #e6c86e; margin-bottom: 16rpx; }
.coming-text { font-size: 28rpx; color: #94a3b8; margin-bottom: 40rpx; }
.coming-hint { font-size: 22rpx; color: #475569; }
