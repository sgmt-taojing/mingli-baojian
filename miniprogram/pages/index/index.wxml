<!-- pages/index/index.wxml — 命理宝鉴·功能大厅 -->
<view class="page-index">
  <!-- 顶部横幅 -->
  <view class="hero">
    <view class="hero-badge" wx:if="{{isBeta}}">🎉 全功能免费体验中</view>
    <view class="hero-title">命理宝鉴</view>
    <view class="hero-subtitle">知命改运 · 趋吉避凶 · 服务生活</view>
    <view class="hero-date">{{today}}</view>
    <view class="hero-wisdom">{{dailyWisdom}}</view>
  </view>

  <!-- 功能板块 -->
  <view class="sections">
    <view class="section" wx:for="{{sections}}" wx:key="id" wx:for-item="section">
      <view class="section-header">
        <text class="section-icon">{{section.icon}}</text>
        <text class="section-title">{{section.title}}</text>
      </view>
      <view class="section-grid">
        <view
          class="grid-item"
          wx:for="{{section.items}}"
          wx:key="id"
          wx:for-item="item"
          data-path="{{item.path}}"
          data-name="{{item.name}}"
          bindtap="onItemTap"
          hover-class="grid-item-hover"
        >
          <view class="grid-card">
            <view class="item-vip" wx:if="{{!isBeta && item.vip}}">VIP</view>
            <view class="item-icon">{{item.icon}}</view>
            <view class="item-name">{{item.name}}</view>
            <view class="item-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部声明 -->
  <view class="footer">
    <view class="footer-text">命理宝鉴 · 传统文化智慧传承</view>
    <view class="footer-disclaimer">本平台内容仅供文化交流，不构成任何决策建议</view>
  </view>
</view>
