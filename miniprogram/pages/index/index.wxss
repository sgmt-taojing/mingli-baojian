/* pages/index/index.wxss */
.page-index { padding: 0 0 40rpx; }

.hero {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #e6c86e;
  letter-spacing: 8rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  letter-spacing: 4rpx;
}

.hero-date {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 16rpx;
}

.wisdom-card {
  margin: 30rpx;
  text-align: center;
}

.wisdom-label {
  font-size: 24rpx;
  color: #e6c86e;
  margin-bottom: 12rpx;
}

.wisdom-text {
  font-size: 30rpx;
  color: #f0f0f0;
  line-height: 1.8;
}

.user-bar {
  margin: 0 30rpx 20rpx;
  background: rgba(230, 200, 110, 0.1);
  border: 2rpx solid rgba(230, 200, 110, 0.3);
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-bar-text { font-size: 28rpx; color: #e6c86e; }
.user-bar-arrow { font-size: 36rpx; color: #e6c86e; }

.menu-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}

.menu-item {
  width: 50%;
  box-sizing: border-box;
  padding: 10rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #16213e;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin: 6rpx;
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  width: 80rpx;
  text-align: center;
}

.menu-info { flex: 1; }

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f0f0f0;
}

.menu-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 30rpx 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #64748b;
}

.footer-disclaimer {
  font-size: 20rpx;
  color: #475569;
  margin-top: 8rpx;
}
