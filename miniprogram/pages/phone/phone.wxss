.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-hint { font-size: 26rpx; color: #94a3b8; margin-bottom: 24rpx; }
.input-phone {
  background: #0f172a; border: 2rpx solid #2a3a5c; border-radius: 12rpx;
  padding: 20rpx; color: #f0f0f0; font-size: 32rpx; text-align: center;
  margin-bottom: 24rpx; letter-spacing: 4rpx;
}
.result-score { text-align: center; padding: 40rpx 28rpx; }
.score-num { font-size: 88rpx; font-weight: 800; line-height: 1.2; }
.score-good { color: #4ade80; }
.score-bad { color: #f87171; }
.score-level { font-size: 36rpx; font-weight: 700; margin-top: 8rpx; }
.level-good { color: #4ade80; }
.level-bad { color: #f87171; }
.score-desc { font-size: 24rpx; color: #94a3b8; margin-top: 12rpx; }
.wuxing-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.wuxing-item { display: flex; flex-direction: column; align-items: center; flex: 1; min-width: 100rpx; padding: 16rpx; background: #0f172a; border-radius: 12rpx; }
.wuxing-name { font-size: 28rpx; color: #e6c86e; font-weight: 600; }
.wuxing-count { font-size: 24rpx; color: #94a3b8; margin-top: 4rpx; }
.digit-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.digit-item { display: flex; flex-direction: column; align-items: center; width: 56rpx; padding: 12rpx 0; background: #0f172a; border-radius: 10rpx; }
.digit-pos { font-size: 20rpx; color: #64748b; }
.digit-num { font-size: 32rpx; font-weight: 700; }
.digit-wx { font-size: 22rpx; }
.baxing-list { display: flex; flex-direction: column; gap: 16rpx; }
.baxing-item { background: #0f172a; border-radius: 12rpx; padding: 20rpx; }
.baxing-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.baxing-pos { font-size: 24rpx; color: #94a3b8; }
.baxing-name { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; font-weight: 600; }
.tag-good { background: rgba(74,222,128,0.15); color: #4ade80; }
.tag-bad { background: rgba(248,113,113,0.15); color: #f87171; }
.baxing-desc { font-size: 26rpx; color: #f0f0f0; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
