.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.date-card { display: flex; justify-content: space-between; align-items: center; }
.date-text { font-size: 30rpx; color: #f0f0f0; font-weight: 600; }
.date-gz { font-size: 26rpx; color: #e6c86e; }
.fortune-list { display: flex; flex-direction: column; gap: 16rpx; }
.fortune-item { padding: 24rpx; }
.fort-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.fort-zodiac { font-size: 34rpx; font-weight: 700; color: #e6c86e; min-width: 60rpx; }
.fort-star { font-size: 24rpx; color: #e6c86e; }
.fort-level { font-size: 28rpx; font-weight: 600; flex: 1; }
.fort-score { font-size: 36rpx; font-weight: 800; }
.fort-dims { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.dim-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 12rpx; background: #0f172a; border-radius: 10rpx; }
.dim-label { font-size: 22rpx; color: #94a3b8; }
.dim-score { font-size: 32rpx; font-weight: 700; color: #e6c86e; }
.fort-advice { display: flex; flex-direction: column; gap: 6rpx; }
.advice-line { font-size: 24rpx; color: #f0f0f0; line-height: 1.6; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
