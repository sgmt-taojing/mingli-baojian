.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 0 20rpx; }
.form-label { font-size: 28rpx; color: #94a3b8; }
.form-input { flex: 1; text-align: right; background: #0f172a; border: 2rpx solid #2a3a5c; border-radius: 10rpx; padding: 16rpx 20rpx; color: #f0f0f0; font-size: 28rpx; margin-left: 20rpx; }
.picker-text { color: #e6c86e; font-size: 28rpx; }
.gua-card { text-align: center; padding: 40rpx 28rpx; }
.gua-symbol { font-size: 96rpx; color: #e6c86e; line-height: 1.4; }
.gua-name { font-size: 40rpx; font-weight: 700; color: #e6c86e; margin-top: 12rpx; }
.gua-ci { font-size: 26rpx; color: #94a3b8; margin-top: 8rpx; }
.yao-list { display: flex; flex-direction: column; gap: 8rpx; }
.yao-item { display: flex; align-items: center; justify-content: space-between; padding: 8rpx 20rpx; background: #0f172a; border-radius: 8rpx; }
.yao-pos { font-size: 24rpx; color: #94a3b8; width: 100rpx; }
.yao-symbol { font-size: 28rpx; color: #f0f0f0; letter-spacing: 2rpx; flex: 1; text-align: center; }
.yao-bian { color: #e6c86e; font-weight: 700; }
.yao-type { font-size: 22rpx; color: #94a3b8; width: 80rpx; text-align: right; }
.bian-info { text-align: center; font-size: 24rpx; color: #e6c86e; margin-top: 12rpx; }
.gua-desc { font-size: 28rpx; color: #f0f0f0; line-height: 1.8; }
.gua-advice { font-size: 28rpx; color: #4ade80; line-height: 1.8; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
