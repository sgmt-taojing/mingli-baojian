.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0 20rpx; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.category-bar { white-space: nowrap; margin-bottom: 24rpx; }
.cat-item { display: inline-block; padding: 12rpx 28rpx; margin-right: 12rpx; border-radius: 10rpx; font-size: 26rpx; color: #94a3b8; background: #16213e; }
.cat-active { background: #e6c86e; color: #1a1a2e; font-weight: 600; }
.course-list { display: flex; flex-direction: column; gap: 20rpx; }
.course-card { display: flex; gap: 20rpx; padding: 24rpx; }
.course-cover { font-size: 60rpx; width: 100rpx; height: 100rpx; display: flex; align-items: center; justify-content: center; background: #0f172a; border-radius: 12rpx; flex-shrink: 0; }
.course-info { flex: 1; }
.course-title { font-size: 30rpx; font-weight: 600; color: #f0f0f0; margin-bottom: 8rpx; }
.course-meta { display: flex; gap: 20rpx; margin-bottom: 8rpx; }
.meta-text { font-size: 22rpx; color: #94a3b8; }
.course-desc { font-size: 24rpx; color: #94a3b8; line-height: 1.5; margin-bottom: 12rpx; }
.course-tag { display: flex; align-items: center; gap: 12rpx; }
.tag { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.tag-free { background: rgba(74,222,128,0.15); color: #4ade80; }
.tag-vip { background: rgba(230,200,110,0.15); color: #e6c86e; }
.price { font-size: 24rpx; color: #e6c86e; font-weight: 600; }
