.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 0 20rpx; }
.form-label { font-size: 28rpx; color: #94a3b8; }
.picker-text { color: #e6c86e; font-size: 28rpx; }
.info-row { display: flex; justify-content: space-between; padding: 10rpx 0; border-bottom: 1rpx solid #2a3a5c; }
.info-row:last-child { border-bottom: none; }
.info-label { color: #94a3b8; font-size: 26rpx; }
.info-value { color: #f0f0f0; font-size: 26rpx; text-align: right; flex: 1; margin-left: 20rpx; }
.quejiao-list { display: flex; flex-direction: column; gap: 12rpx; }
.quejiao-item { padding: 16rpx 20rpx; background: rgba(248,113,113,0.08); border-radius: 10rpx; border-left: 6rpx solid #f87171; }
.quejiao-impact { font-size: 26rpx; color: #f0f0f0; }
.fangwei-list { display: flex; flex-direction: column; gap: 12rpx; }
.fangwei-item { background: #0f172a; border-radius: 10rpx; padding: 16rpx 20rpx; }
.fw-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.fw-dir { font-size: 28rpx; font-weight: 600; color: #e6c86e; }
.fw-level { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 600; }
.lv-good { background: rgba(74,222,128,0.15); color: #4ade80; }
.lv-bad { background: rgba(248,113,113,0.15); color: #f87171; }
.lv-mid { background: rgba(230,200,110,0.15); color: #e6c86e; }
.fw-detail { display: flex; flex-direction: column; gap: 4rpx; }
.fw-info { font-size: 22rpx; color: #94a3b8; }
.fw-topic { font-size: 22rpx; color: #a78bfa; }
.fw-reason { font-size: 24rpx; color: #f0f0f0; }
.remedy-list { display: flex; flex-direction: column; gap: 10rpx; }
.remedy-item { font-size: 26rpx; color: #4ade80; line-height: 1.6; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
