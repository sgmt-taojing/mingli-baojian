.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 0 20rpx; }
.form-label { font-size: 28rpx; color: #94a3b8; }
.picker-text { color: #e6c86e; font-size: 28rpx; }
.result-score { text-align: center; padding: 30rpx; }
.tizhi-name { font-size: 40rpx; font-weight: 700; color: #e6c86e; }
.tizhi-desc { font-size: 26rpx; color: #94a3b8; margin-top: 8rpx; }
.wx-bar-list { display: flex; flex-direction: column; gap: 12rpx; }
.wx-bar-item { display: flex; align-items: center; gap: 16rpx; }
.wx-bar-name { font-size: 28rpx; color: #e6c86e; width: 40rpx; }
.wx-bar-bg { flex: 1; height: 24rpx; background: #0f172a; border-radius: 12rpx; overflow: hidden; }
.wx-bar-fill { height: 100%; border-radius: 12rpx; }
.wx-木 { background: #4ade80; }
.wx-火 { background: #f87171; }
.wx-土 { background: #a78bfa; }
.wx-金 { background: #e6c86e; }
.wx-水 { background: #60a5fa; }
.wx-bar-count { font-size: 24rpx; color: #94a3b8; width: 40rpx; }
.feature-list, .advice-list { display: flex; flex-direction: column; gap: 8rpx; }
.feature-item, .advice-item { font-size: 28rpx; color: #f0f0f0; line-height: 1.8; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
