.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.form-label { font-size: 28rpx; color: #cbd5e1; }
.picker-text { font-size: 28rpx; color: #e6c86e; }
.btn-primary { background: #e6c86e; color: #1a1a2e; border: none; border-radius: 12rpx; padding: 20rpx 0; font-size: 30rpx; font-weight: 600; width: 100%; }
.card { background: #16213e; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; color: #e6c86e; font-weight: 600; margin-bottom: 16rpx; }
.card-warning { border: 2rpx solid rgba(239,68,68,0.2); }
.result-score { text-align: center; padding: 40rpx 28rpx; }
.tizhi-name { font-size: 40rpx; font-weight: 700; color: #e6c86e; margin-bottom: 12rpx; }
.tizhi-desc { font-size: 26rpx; color: #94a3b8; line-height: 1.6; }
.wx-bar-list { display: flex; flex-direction: column; gap: 12rpx; }
.wx-bar-item { display: flex; align-items: center; gap: 16rpx; }
.wx-bar-name { font-size: 26rpx; color: #cbd5e1; min-width: 40rpx; }
.wx-bar-bg { flex: 1; height: 24rpx; background: #0f172a; border-radius: 12rpx; overflow: hidden; }
.wx-bar-fill { height: 100%; border-radius: 12rpx; transition: width .3s; }
.wx-木 { background: #4ade80; }
.wx-火 { background: #f87171; }
.wx-土 { background: #fbbf24; }
.wx-金 { background: #e6c86e; }
.wx-水 { background: #60a5fa; }
.wx-bar-count { font-size: 24rpx; color: #e6c86e; min-width: 30rpx; text-align: right; }
.feature-list { display: flex; flex-direction: column; gap: 8rpx; }
.feature-item { font-size: 26rpx; color: #f0f0f0; line-height: 1.8; }
.food-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.food-tag { font-size: 24rpx; color: #e6c86e; background: rgba(201,168,76,0.1); border: 1rpx solid rgba(201,168,76,0.2); border-radius: 20rpx; padding: 8rpx 20rpx; }
.advice-list { display: flex; flex-direction: column; gap: 10rpx; }
.advice-item { font-size: 26rpx; color: #cbd5e1; line-height: 1.7; }
.season-advice { font-size: 26rpx; color: #cbd5e1; line-height: 1.8; }
.taboo-text { font-size: 26rpx; color: #fca5a5; line-height: 1.8; }
.loading { text-align: center; padding: 40rpx; color: #94a3b8; font-size: 28rpx; }
