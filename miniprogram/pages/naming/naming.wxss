.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 0 20rpx; }
.form-label { font-size: 28rpx; color: #94a3b8; }
.form-input { flex: 1; text-align: right; background: #0f172a; border: 2rpx solid #2a3a5c; border-radius: 10rpx; padding: 16rpx 20rpx; color: #f0f0f0; font-size: 28rpx; margin-left: 20rpx; }
.picker-text { color: #e6c86e; font-size: 28rpx; }
.result-score { text-align: center; padding: 30rpx; }
.score-num { font-size: 80rpx; font-weight: 800; }
.score-good { color: #4ade80; }
.score-bad { color: #f87171; }
.score-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.gege-list { display: flex; flex-direction: column; gap: 12rpx; }
.gege-item { display: flex; align-items: center; gap: 20rpx; padding: 16rpx 20rpx; background: #0f172a; border-radius: 10rpx; }
.gege-name { font-size: 28rpx; color: #e6c86e; font-weight: 600; min-width: 120rpx; }
.gege-value { font-size: 32rpx; color: #f0f0f0; font-weight: 700; min-width: 80rpx; }
.gege-jx { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; }
.tag-good { background: rgba(74,222,128,0.15); color: #4ade80; }
.tag-bad { background: rgba(248,113,113,0.15); color: #f87171; }
.word-cloud { display: flex; flex-wrap: wrap; gap: 16rpx; }
.word-item { padding: 10rpx 24rpx; background: #0f172a; border: 2rpx solid #2a3a5c; border-radius: 10rpx; font-size: 32rpx; color: #e6c86e; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
