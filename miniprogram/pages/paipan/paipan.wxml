<!-- pages/paipan/paipan.wxml — 多术数排盘 -->
<view class="page-paipan">
  <!-- 术数类型选择 -->
  <scroll-view class="type-bar" scroll-x>
    <view class="type-item {{currentType === item.id ? 'active' : ''}}" wx:for="{{types}}" wx:key="id" data-id="{{item.id}}" bindtap="onTypeTap">
      <text class="type-icon">{{item.icon}}</text>
      <text class="type-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 表单区 -->
  <view class="card form-card">
    <view class="card-title">{{currentTypeName}}</view>

    <!-- 八字/紫微 表单 -->
    <block wx:if="{{currentType === 'bazi' || currentType === 'ziwei'}}">
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" data-key="name" bindinput="onInput" value="{{form.name}}" />
      </view>
      <view class="form-row">
        <text class="form-label">性别</text>
        <radio-group bindchange="onSexChange">
          <label class="radio-label"><radio value="male" checked="{{form.sex === 'male'}}" />男</label>
          <label class="radio-label"><radio value="female" checked="{{form.sex === 'female'}}" />女</label>
        </radio-group>
      </view>
      <view class="form-row">
        <text class="form-label">出生日期</text>
        <picker mode="date" value="{{form.birthDate}}" bindchange="onDateChange">
          <view class="form-picker">{{form.birthDate}}</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">出生时辰</text>
        <picker mode="selector" range="{{shichenList}}" value="{{form.birthHour}}" bindchange="onHourChange">
          <view class="form-picker">{{shichenList[form.birthHour]}}</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">出生地</text>
        <input class="form-input" placeholder="省市（可选）" data-key="birthplace" bindinput="onInput" value="{{form.birthplace}}" />
      </view>
    </block>

    <!-- 奇门/六壬/六爻/梅花 表单 -->
    <block wx:wx:else>
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" data-key="name" bindinput="onInput" value="{{form.name}}" />
      </view>
      <view class="form-row">
        <text class="form-label">性别</text>
        <radio-group bindchange="onSexChange">
          <label class="radio-label"><radio value="male" checked="{{form.sex === 'male'}}" />男</label>
          <label class="radio-label"><radio value="female" checked="{{form.sex === 'female'}}" />女</label>
        </radio-group>
      </view>
      <view class="form-row">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{form.birthDate}}" bindchange="onDateChange">
          <view class="form-picker">{{form.birthDate}}</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">问事类型</text>
        <picker mode="selector" range="{{questionTypes}}" bindchange="onQuestionTypeChange">
          <view class="form-picker">{{form.questionType}}</view>
        </picker>
      </view>
      <view class="form-row" wx:if="{{currentType === 'meihua'}}">
        <text class="form-label">起卦数字</text>
        <input class="form-input" type="number" placeholder="输入1-99数字（可选）" data-key="meihuaNum" bindinput="onInput" value="{{form.meihuaNum}}" />
      </view>
    </block>

    <button class="btn-primary" bindtap="onCalculate" loading="{{loading}}">开始排盘</button>
  </view>

  <!-- 结果区 -->
  <view class="card result-card" wx:if="{{result}}">
    <view class="card-title">排盘结果</view>

    <!-- 八字结果 -->
    <block wx:if="{{result.type === 'bazi'}}">
      <view class="result-basic">
        <text>{{result.basic.name}}</text>
        <text class="result-sep">|</text>
        <text>{{result.basic.sex}}</text>
        <text class="result-sep">|</text>
        <text>{{result.basic.date}}</text>
        <text class="result-sep">|</text>
        <text>{{result.basic.hour}}</text>
      </view>
      <view class="pillars-grid">
        <view class="pillar-item">
          <view class="pillar-label">年柱</view>
          <view class="pillar-value">{{result.pillars.year}}</view>
        </view>
        <view class="pillar-item">
          <view class="pillar-label">月柱</view>
          <view class="pillar-value">{{result.pillars.month}}</view>
        </view>
        <view class="pillar-item">
          <view class="pillar-label">日柱</view>
          <view class="pillar-value">{{result.pillars.day}}</view>
        </view>
        <view class="pillar-item">
          <view class="pillar-label">时柱</view>
          <view class="pillar-value">{{result.pillars.hour}}</view>
        </view>
      </view>
      <view class="result-interpretation">{{result.interpretation}}</view>
    </block>

    <!-- 其他术数结果 -->
    <block wx:else>
      <view class="result-basic">
        <text>{{result.basic.name}}</text>
        <text class="result-sep">|</text>
        <text>{{result.basic.date}}</text>
      </view>
      <view class="result-interpretation">{{result.interpretation}}</view>
    </block>

    <view class="result-actions">
      <button class="btn-outline" bindtap="onSave">保存记录</button>
      <button class="btn-outline" open-type="share">分享</button>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">正在排盘中...</view>

  <!-- 历史记录 -->
  <view class="card" wx:if="{{history.length > 0}}">
    <view class="card-title">历史记录</view>
    <view class="history-item" wx:for="{{history}}" wx:key="id">
      <text class="history-name">{{item.name}}</text>
      <text class="history-date">{{item.birth_date}}</text>
    </view>
  </view>
</view>
