/* pages/paipan/paipan.wxss */
.page-paipan { padding: 0 0 40rpx; }

.type-bar {
  display: flex;
  white-space: nowrap;
  padding: 20rpx;
  background: #16213e;
  position: sticky;
  top: 0;
  z-index: 10;
}

.type-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  background: #1a1a2e;
  min-width: 120rpx;
}

.type-item.active {
  background: rgba(230, 200, 110, 0.15);
  border-bottom: 4rpx solid #e6c86e;
}

.type-icon { font-size: 36rpx; }
.type-name { font-size: 22rpx; color: #94a3b8; margin-top: 6rpx; }
.type-item.active .type-name { color: #e6c86e; }

.form-card { margin: 20rpx; }

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #2a3a5c;
}

.form-label { width: 160rpx; font-size: 28rpx; color: #94a3b8; flex-shrink: 0; }
.form-input { flex: 1; background: #1e2a4a; border: 2rpx solid #2a3a5c; border-radius: 8rpx; padding: 12rpx 20rpx; color: #f0f0f0; font-size: 28rpx; }
.form-picker { flex: 1; color: #f0f0f0; font-size: 28rpx; padding: 12rpx 0; }

.radio-label { margin-right: 30rpx; font-size: 28rpx; color: #f0f0f0; }

.form-card .btn-primary { margin-top: 30rpx; }

.result-card { margin: 20rpx; border: 2rpx solid rgba(230, 200, 110, 0.3); }

.result-basic { font-size: 26rpx; color: #f0f0f0; margin-bottom: 20rpx; }
.result-sep { color: #475569; margin: 0 12rpx; }

.pillars-grid {
  display: flex;
  justify-content: space-around;
  margin: 24rpx 0;
  padding: 20rpx 0;
  background: #0f3460;
  border-radius: 12rpx;
}

.pillar-item { text-align: center; }
.pillar-label { font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx; }
.pillar-value { font-size: 36rpx; font-weight: 700; color: #e6c86e; }

.result-interpretation {
  font-size: 26rpx;
  color: #cbd5e1;
  line-height: 1.8;
  padding: 16rpx 0;
  border-top: 1rpx solid #2a3a5c;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.result-actions .btn-outline { flex: 1; }

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #2a3a5c;
}

.history-name { font-size: 28rpx; color: #f0f0f0; }
.history-date { font-size: 24rpx; color: #64748b; }
