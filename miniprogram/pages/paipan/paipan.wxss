/* pages/paipan/paipan.wxss */

.container {
  min-height: 100vh;
  background: #1a1a2e;
  padding: 30rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 通用卡片 ===== */
.card {
  background: #16213e;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(230, 200, 110, 0.12);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  color: #e6c86e;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #e6c86e;
  flex: 1;
}

.toggle-arrow {
  color: #e6c86e;
  font-size: 28rpx;
}

/* ===== 标题 ===== */
.page-title {
  text-align: center;
  padding: 20rpx 0 36rpx;
}

.title-main {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #e6c86e;
  letter-spacing: 8rpx;
}

.title-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(230, 200, 110, 0.5);
  margin-top: 10rpx;
  letter-spacing: 4rpx;
}

/* ===== 表单 ===== */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: rgba(240, 240, 240, 0.7);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: rgba(26, 26, 46, 0.8);
  border: 1rpx solid rgba(230, 200, 110, 0.2);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #f0f0f0;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: rgba(240, 240, 240, 0.3);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  background: rgba(26, 26, 46, 0.8);
  border: 1rpx solid rgba(230, 200, 110, 0.2);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #f0f0f0;
  box-sizing: border-box;
}

.picker-arrow {
  color: rgba(230, 200, 110, 0.6);
  font-size: 28rpx;
}

/* ===== 排盘按钮 ===== */
.btn-paipan {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #e6c86e 0%, #c8a14b 100%) !important;
  color: #1a1a2e !important;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 16rpx;
  border: none;
  margin-top: 36rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(230, 200, 110, 0.3);
}

.btn-paipan[disabled] {
  opacity: 0.6;
}

.btn-paipan::after {
  border: none;
}

/* ===== 排盘结果 ===== */
.result-card {
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-summary {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(230, 200, 110, 0.1);
}

.summary-item {
  font-size: 28rpx;
  color: #f0f0f0;
}

.summary-divider {
  color: rgba(230, 200, 110, 0.3);
  margin: 0 16rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e6c86e;
  margin: 32rpx 0 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e6c86e;
}

/* ===== 四柱网格 ===== */
.sizhu-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.sizhu-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sizhu-col-title {
  font-size: 26rpx;
  color: rgba(230, 200, 110, 0.7);
  margin-bottom: 16rpx;
}

.sizhu-cell {
  width: 100%;
  text-align: center;
  padding: 12rpx 0;
  margin-bottom: 8rpx;
  border-radius: 10rpx;
}

.sizhu-gan {
  background: rgba(230, 200, 110, 0.12);
}

.sizhu-zhi {
  background: rgba(230, 200, 110, 0.08);
}

.sizhu-char {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #e6c86e;
  line-height: 1.4;
}

.sizhu-sub {
  display: block;
  font-size: 20rpx;
  color: rgba(240, 240, 240, 0.5);
}

.sizhu-label {
  display: block;
  font-size: 20rpx;
  color: rgba(240, 240, 240, 0.4);
  margin-bottom: 4rpx;
}

.sizhu-cang-text {
  font-size: 24rpx;
  color: rgba(240, 240, 240, 0.8);
}

.sizhu-cang,
.sizhu-shishen,
.sizhu-nayin {
  background: rgba(26, 26, 46, 0.5);
}

/* ===== 五行力量 ===== */
.wuxing-bar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wuxing-item {
  display: flex;
  align-items: center;
}

.wuxing-name {
  width: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #f0f0f0;
}

.wuxing-progress-bg {
  flex: 1;
  height: 24rpx;
  background: rgba(26, 26, 46, 0.8);
  border-radius: 12rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.wuxing-progress-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

.wuxing-percent {
  width: 70rpx;
  text-align: right;
  font-size: 24rpx;
  color: rgba(240, 240, 240, 0.7);
}

/* ===== 神煞 ===== */
.shensha-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.shensha-tag {
  background: rgba(230, 200, 110, 0.1);
  border: 1rpx solid rgba(230, 200, 110, 0.25);
  border-radius: 24rpx;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  color: #e6c86e;
}

/* ===== 大运 ===== */
.dayun-table {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.dayun-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(230, 200, 110, 0.08);
}

.dayun-row:last-child {
  border-bottom: none;
}

.dayun-header {
  background: rgba(230, 200, 110, 0.1);
}

.dayun-header .dayun-cell {
  font-size: 24rpx;
  color: #e6c86e;
  font-weight: 600;
}

.dayun-cell {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: rgba(240, 240, 240, 0.8);
}

.dayun-ganzhi {
  font-weight: 600;
  color: #e6c86e;
}

/* ===== Loading ===== */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(230, 200, 110, 0.2);
  border-top-color: #e6c86e;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(230, 200, 110, 0.7);
}

/* ===== 历史记录 ===== */
.history-list {
  margin-top: 8rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(230, 200, 110, 0.06);
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: rgba(230, 200, 110, 0.05);
}

.history-item-left {
  display: flex;
  flex-direction: column;
}

.history-name {
  font-size: 30rpx;
  color: #f0f0f0;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.history-info {
  font-size: 24rpx;
  color: rgba(240, 240, 240, 0.4);
}

.history-arrow {
  font-size: 36rpx;
  color: rgba(230, 200, 110, 0.4);
}

/* ===== 底部 ===== */
.bottom-spacer {
  height: 40rpx;
}
