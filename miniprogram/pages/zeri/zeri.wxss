.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.func-form { text-align: center; }
.form-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 0 20rpx; }
.form-label { font-size: 28rpx; color: #94a3b8; }
.picker-text { color: #e6c86e; font-size: 28rpx; }
.day-list { display: flex; flex-direction: column; gap: 16rpx; }
.day-item { background: #0f172a; border-radius: 12rpx; padding: 20rpx; border-left: 6rpx solid #4ade80; }
.day-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.day-date { font-size: 30rpx; font-weight: 600; color: #f0f0f0; }
.day-score { font-size: 28rpx; color: #e6c86e; font-weight: 700; }
.day-ganzi { display: flex; gap: 20rpx; margin-bottom: 8rpx; }
.day-gz { font-size: 26rpx; color: #a78bfa; }
.day-jc { font-size: 24rpx; color: #94a3b8; }
.day-chong { font-size: 24rpx; color: #f87171; }
.day-yiji { display: flex; flex-direction: column; gap: 4rpx; }
.yi-label { font-size: 24rpx; color: #4ade80; }
.ji-label { font-size: 24rpx; color: #f87171; }
.empty-text { font-size: 28rpx; color: #94a3b8; text-align: center; padding: 20rpx; }
.loading { text-align: center; color: #94a3b8; padding: 30rpx; }
