/* pages/mine/mine.wxss */

page {
  background-color: #1a1a2e;
  min-height: 100vh;
}

.page {
  background-color: #1a1a2e;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ========== 未登录 ========== */
.login-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 120rpx;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #16213e;
  border: 4rpx solid #e6c86e;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.avatar-icon {
  font-size: 72rpx;
}

.login-hint {
  font-size: 36rpx;
  color: #e6c86e;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.login-sub {
  font-size: 26rpx;
  color: #888;
}

/* ========== 用户信息卡片 ========== */
.user-card {
  display: flex;
  align-items: center;
  background: #16213e;
  margin: 24rpx;
  padding: 36rpx 32rpx;
  border-radius: 20rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #e6c86e;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

.vip-badge {
  background: linear-gradient(135deg, #e6c86e, #d4a843);
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
}

.vip-text {
  font-size: 22rpx;
  color: #1a1a2e;
  font-weight: 700;
}

.user-phone {
  font-size: 26rpx;
  color: #aaa;
}

/* ========== 通用 Section ========== */
.section {
  background: #16213e;
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  color: #e6c86e;
  font-weight: 600;
}

.section-edit {
  font-size: 26rpx;
  color: #888;
}

/* ========== 生辰信息 ========== */
.birth-info {
  padding: 0 32rpx 28rpx;
}

.birth-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.birth-row:last-child {
  border-bottom: none;
}

.birth-label {
  font-size: 28rpx;
  color: #888;
}

.birth-value {
  font-size: 28rpx;
  color: #ddd;
}

/* ========== 编辑模式 ========== */
.birth-edit {
  padding: 0 32rpx 28rpx;
}

.edit-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.edit-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #888;
  flex-shrink: 0;
}

.edit-input {
  flex: 1;
  font-size: 28rpx;
  color: #ddd;
}

.edit-radio-group {
  display: flex;
  gap: 40rpx;
}

.radio-label {
  font-size: 28rpx;
  color: #ddd;
  display: flex;
  align-items: center;
}

.edit-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #2a2a4a;
  color: #aaa;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-save {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #e6c86e, #d4a843);
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
}

/* ========== 排盘历史 ========== */
.history-list {
  padding: 0 32rpx 20rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-name {
  font-size: 28rpx;
  color: #ddd;
}

.history-date {
  font-size: 24rpx;
  color: #666;
}

.history-arrow {
  font-size: 36rpx;
  color: #555;
}

.empty-tip {
  padding: 40rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

/* ========== 积分 ========== */
.points-section {
  padding: 0 32rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
}

.points-label {
  font-size: 30rpx;
  color: #ddd;
}

.points-value {
  font-size: 40rpx;
  color: #e6c86e;
  font-weight: 700;
}

/* ========== 功能菜单 ========== */
.menu-section {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #ddd;
}

.menu-arrow {
  font-size: 36rpx;
  color: #555;
}

/* ========== 退出登录 ========== */
.logout-section {
  margin: 48rpx 24rpx;
}

.logout-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #2a2a4a;
  color: #e0506e;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 1rpx solid rgba(224, 80, 110, 0.3);
}

/* ========== 登录弹窗 ========== */
.login-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.login-popup {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #16213e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.popup-title {
  font-size: 34rpx;
  color: #e6c86e;
  font-weight: 600;
  margin-bottom: 36rpx;
}

.phone-input {
  width: 100%;
  height: 88rpx;
  background: #1a1a2e;
  border: 1rpx solid rgba(230, 200, 110, 0.3);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #ddd;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #e6c86e, #d4a843);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.login-btn.loading {
  opacity: 0.6;
}

.popup-cancel {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #888;
  padding: 16rpx;
}
