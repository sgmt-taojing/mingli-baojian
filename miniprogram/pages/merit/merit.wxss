.page-func { padding: 30rpx; }
.func-header { text-align: center; padding: 40rpx 0 20rpx; }
.func-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.func-title { font-size: 36rpx; font-weight: 700; color: #e6c86e; }
.func-desc { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }
.merit-summary { display: flex; align-items: center; justify-content: space-around; padding: 30rpx; }
.summary-item { display: flex; flex-direction: column; align-items: center; }
.summary-num { font-size: 44rpx; font-weight: 800; color: #e6c86e; }
.summary-label { font-size: 24rpx; color: #94a3b8; margin-top: 4rpx; }
.small-date { font-size: 20rpx; }
.summary-divider { width: 2rpx; height: 60rpx; background: #2a3a5c; }
.checkin-list { display: flex; flex-direction: column; gap: 16rpx; }
.checkin-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx; background: #0f172a; border-radius: 12rpx; border: 2rpx solid transparent; transition: border-color 0.2s; }
.checkin-item.done { border-color: #4ade80; }
.checkin-icon { font-size: 48rpx; width: 80rpx; text-align: center; }
.checkin-info { flex: 1; display: flex; flex-direction: column; }
.checkin-name { font-size: 30rpx; font-weight: 600; color: #f0f0f0; }
.checkin-desc { font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }
.checkin-points { font-size: 22rpx; color: #e6c86e; margin-top: 4rpx; }
.checkin-status { width: 56rpx; height: 56rpx; border-radius: 50%; border: 4rpx solid #2a3a5c; display: flex; align-items: center; justify-content: center; }
.checkin-item.done .checkin-status { border-color: #4ade80; background: #4ade80; }
.status-text { font-size: 32rpx; color: #1a1a2e; font-weight: 700; }
.week-grid { display: flex; justify-content: space-between; gap: 8rpx; }
.week-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0; background: #0f172a; border-radius: 10rpx; }
.week-today { border: 2rpx solid #e6c86e; }
.week-date { font-size: 22rpx; color: #94a3b8; }
.week-count { font-size: 24rpx; color: #e6c86e; margin-top: 4rpx; }
