<!-- MAIN -->
<div class="main">

<!-- ===== 新缘主引导区 ===== -->
<div class="guide-banner" id="guideBanner" style="max-width:1100px;margin:80px auto 0;padding:0 40px">
  <div class="guide-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <div class="guide-title" style="font-family:'Ma Shan Zheng',serif;font-size:22px;letter-spacing:5px;color:var(--gold)">🎯 第一次使用？三步开启您的命理之旅</div>
    <button class="guide-toggle" onclick="toggleGuide()" style="background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);color:var(--gold);padding:6px 14px;font-size:12px;letter-spacing:2px;cursor:pointer;font-family:'Noto Serif SC',serif;border-radius:4px">收起 ▲</button>
  </div>
  <div class="guide-steps" id="guideSteps" style="display:flex;gap:16px;align-items:center;justify-content:center;flex-wrap:wrap;margin-bottom:24px">
    <div class="guide-step" style="flex:1;min-width:200px;max-width:280px;padding:20px;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);border-radius:8px;text-align:center;cursor:pointer;transition:all .3s" onmouseover="this.style.borderColor='rgba(201,168,76,0.4)';this.style.background='rgba(201,168,76,0.05)'" onmouseout="this.style.borderColor='rgba(201,168,76,0.15)';this.style.background='rgba(255,255,255,0.03)'" onclick="showSection('bazi')">
      <div style="font-family:'Ma Shan Zheng',serif;font-size:32px;color:var(--gold);margin-bottom:8px">①</div>
      <div style="font-size:15px;letter-spacing:3px;color:var(--paper2);margin-bottom:6px">输入出生信息</div>
      <div style="font-size:12px;opacity:.5;letter-spacing:1px">填写姓名、日期、时辰</div>
    </div>
    <div style="font-size:20px;color:var(--gold);opacity:.5;flex-shrink:0">→</div>
    <div class="guide-step" style="flex:1;min-width:200px;max-width:280px;padding:20px;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);border-radius:8px;text-align:center;cursor:pointer;transition:all .3s" onmouseover="this.style.borderColor='rgba(201,168,76,0.4)';this.style.background='rgba(201,168,76,0.05)'" onmouseout="this.style.borderColor='rgba(201,168,76,0.15)';this.style.background='rgba(255,255,255,0.03)'" onclick="showSection('bazi')">
      <div style="font-family:'Ma Shan Zheng',serif;font-size:32px;color:var(--gold);margin-bottom:8px">②</div>
      <div style="font-size:15px;letter-spacing:3px;color:var(--paper2);margin-bottom:6px">查看命盘解读</div>
      <div style="font-size:12px;opacity:.5;letter-spacing:1px">八字、五行、十神分析</div>
    </div>
    <div style="font-size:20px;color:var(--gold);opacity:.5;flex-shrink:0">→</div>
    <div class="guide-step" style="flex:1;min-width:200px;max-width:280px;padding:20px;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);border-radius:8px;text-align:center;cursor:pointer;transition:all .3s" onmouseover="this.style.borderColor='rgba(201,168,76,0.4)';this.style.background='rgba(201,168,76,0.05)'" onmouseout="this.style.borderColor='rgba(201,168,76,0.15)';this.style.background='rgba(255,255,255,0.03)'" onclick="showSection('huajie')">
      <div style="font-family:'Ma Shan Zheng',serif;font-size:32px;color:var(--gold);margin-bottom:8px">③</div>
      <div style="font-size:15px;letter-spacing:3px;color:var(--paper2);margin-bottom:6px">获取化解建议</div>
      <div style="font-size:12px;opacity:.5;letter-spacing:1px">开运化解、趋吉避凶</div>
    </div>
  </div>
  <div style="text-align:center;margin-bottom:30px">
    <button onclick="showSection('bazi')" style="padding:14px 48px;background:transparent;border:2px solid var(--gold);color:var(--gold);font-family:'Ma Shan Zheng',serif;font-size:16px;letter-spacing:6px;cursor:pointer;transition:all .35s;border-radius:6px" onmouseover="this.style.background='var(--gold)';this.style.color='var(--ink)'" onmouseout="this.style.background='transparent';this.style.color='var(--gold)'">开始起盘</button>
  </div>
</div>

<!-- ===== HERO ===== -->
<section class="section active" id="section-hero">
  <div class="hero">
    <p class="hero-eyebrow">Ancient Wisdom · Complete Divination Suite</p>
    <h1 class="hero-title">命 理 通 鉴</h1>
    <p class="hero-sub">
      八字命盘 · 易经六爻 · 奇门遁甲 · 紫微斗数 · 梅花易数 · 大六壬
    </p>
    <div class="hero-divider"></div>
    <p class="hero-desc">
      集千年智慧于一器，探命运之玄机<br>
      道法自然，易穷则变，变则通，通则久
    </p>

    <!-- Mobile Welcome Widget -->
    <div class="mobile-hero-welcome">
      <p class="mobile-welcome-title">易道智鉴</p>
      <p class="mobile-welcome-date" id="mobileDateDisplay"></p>
    </div>

    <!-- Today's Fortune Card (Mobile) -->
    <div class="today-fortune-card" id="todayFortuneCard">
      <div class="today-fortune-header">
        <span class="today-fortune-label">今日运势</span>
        <span class="today-fortune-star" id="fortuneStar">★★★☆☆</span>
      </div>
      <div class="today-fortune-title" id="fortuneTitle">壬寅年 · 丙午月</div>
      <div class="today-fortune-yj" id="fortuneYJ">
        <span class="yi-label">宜</span> 祭祀 祈福 动土<br>
        <span class="ji-label">忌</span> 嫁娶 搬家 安葬
      </div>
      <div class="today-fortune-wuxing" id="fortuneWuxing"></div>
    </div>

    <!-- Quick Actions Grid (Mobile) -->
    <div class="mobile-quick-grid" id="mobileQuickGrid">
      <div class="mobile-quick-item" onclick="showSection('bazi')">
        <span class="mobile-quick-icon">🌟</span>
        <div class="mobile-quick-text">
          <div class="mobile-quick-name">八字排盘</div>
          <div class="mobile-quick-desc">四柱命盘分析</div>
        </div>
      </div>
      <div class="mobile-quick-item" onclick="showSection('yijing')">
        <span class="mobile-quick-icon">䷀</span>
        <div class="mobile-quick-text">
          <div class="mobile-quick-name">易经六爻</div>
          <div class="mobile-quick-desc">三枚铜钱问卦</div>
        </div>
      </div>
      <div class="mobile-quick-item" onclick="showSection('qimen')">
        <span class="mobile-quick-icon">☰</span>
        <div class="mobile-quick-text">
          <div class="mobile-quick-name">奇门遁甲</div>
          <div class="mobile-quick-desc">九宫时空决策</div>
        </div>
      </div>
      <div class="mobile-quick-item" onclick="showSection('meihua')">
        <span class="mobile-quick-icon">🌸</span>
        <div class="mobile-quick-text">
          <div class="mobile-quick-name">梅花易数</div>
          <div class="mobile-quick-desc">数字起卦断事</div>
        </div>
      </div>
      <div class="mobile-quick-item" onclick="showSection('huajie')">
        <span class="mobile-quick-icon">🛡️</span>
        <div class="mobile-quick-text">
          <div class="mobile-quick-name">化解开运</div>
          <div class="mobile-quick-desc">五行补缺调运</div>
        </div>
      </div>
      <div class="mobile-quick-item" onclick="showSection('cezi')">
        <span class="mobile-quick-icon">✍️</span>
        <div class="mobile-quick-text">
          <div class="mobile-quick-name">测字</div>
          <div class="mobile-quick-desc">一字洞悉玄机</div>
        </div>
      </div>
    </div>

    <!-- Daily Yiji Banner (Mobile) -->
    <div class="daily-yiji-banner">
      <span class="yi-text">宜</span>祭祀祈福 动土 开业<span class="ji-text">忌</span>嫁娶搬家 安葬<span class="normal-text">诸事不宜远行</span>
    </div>

    <!-- Mobile Huajie Scroll -->
    <div class="mobile-huajie-scroll" id="mobileHuajieScroll">
      <div class="mobile-huajie-card">
        <div class="mobile-huajie-title">🪙 补金开运</div>
        <div class="mobile-huajie-desc">佩戴金属饰品、白色衣物，补足命局金气</div>
      </div>
      <div class="mobile-huajie-card">
        <div class="mobile-huajie-title">🌿 旺木助运</div>
        <div class="mobile-huajie-desc">摆放绿植、东方布局，增强事业运</div>
      </div>
      <div class="mobile-huajie-card">
        <div class="mobile-huajie-title">🔥 化解火煞</div>
        <div class="mobile-huajie-desc">南方忌红色，用水布局化解</div>
      </div>
    </div>

    <div class="cat-grid">
      <div class="cat-card bazi" onclick="showSection('bazi')">
        <span class="cc-symbol">🌟</span>
        <span class="cc-name">八字命盘</span>
        <span class="cc-en">Four Pillars · BaZi</span>
        <p class="cc-desc">以年月日时四柱为基，十神定命，五行论命，大运流年推演一生起伏</p>
        <div class="cc-tags">
          <span class="cat-tag">四柱八字</span>
          <span class="cat-tag">十神分析</span>
          <span class="cat-tag">五行平衡</span>
          <span class="cat-tag">大运流年</span>
        </div>
      </div>

      <div class="cat-card yijing" onclick="showSection('yijing')">
        <span class="cc-symbol">䷀</span>
        <span class="cc-name">易经六爻</span>
        <span class="cc-en">I Ching · 64 Hexagrams</span>
        <p class="cc-desc">三枚铜钱掷六次，金钱课起卦，六十四卦演绎阴阳变化之道</p>
        <div class="cc-tags">
          <span class="cat-tag">金钱课</span>
          <span class="cat-tag">六爻</span>
          <span class="cat-tag">64卦</span>
          <span class="cat-tag">动变分析</span>
        </div>
      </div>

      <div class="cat-card qimen" onclick="showSection('qimen')">
        <span class="cc-symbol">☰</span>
        <span class="cc-name">奇门遁甲</span>
        <span class="cc-en">Qimen Dunjia · Nine Palaces</span>
        <p class="cc-desc">时空为基，九宫排布，八门流转，天星临照，决策天机</p>
        <div class="cc-tags">
          <span class="cat-tag">九宫八门</span>
          <span class="cat-tag">阳遁阴遁</span>
          <span class="cat-tag">九星八神</span>
          <span class="cat-tag">时辰决策</span>
        </div>
      </div>

      <div class="cat-card ziwei" onclick="showSection('ziwei')">
        <span class="cc-symbol">🌌</span>
        <span class="cc-name">紫微斗数</span>
        <span class="cc-en">Zi Wei Dou Shu · Fate Numerology</span>
        <p class="cc-desc">以星曜定命宫，身宫，四化推演，紫微星为诸星之主</p>
        <div class="cc-tags">
          <span class="cat-tag">星曜排布</span>
          <span class="cat-tag">命宫身宫</span>
          <span class="cat-tag">四化星</span>
          <span class="cat-tag">十二宫</span>
        </div>
      </div>

      <div class="cat-card meihua" onclick="showSection('meihua')">
        <span class="cc-symbol">🌸</span>
        <span class="cc-name">梅花易数</span>
        <span class="cc-en">Meihua Yishu · Number Divination</span>
        <p class="cc-desc">以数起卦，体用分阴阳，五行生克论吉凶，简单而神妙</p>
        <div class="cc-tags">
          <span class="cat-tag">数字起卦</span>
          <span class="cat-tag">体用五行</span>
          <span class="cat-tag">万物类象</span>
          <span class="cat-tag">应期判断</span>
        </div>
      </div>

      <div class="cat-card" style="border-color:rgba(230,126,34,.1)" onclick="showSection('liuren')">
        <span class="cc-symbol" style="color:#e67e22">⬡</span>
        <span class="cc-name" style="color:#e67e22">大六壬</span>
        <span class="cc-en">Da Liu Ren · Six Ren</span>
        <p class="cc-desc">六壬为三式之首，以天盘地盘人盘三传演万事，以神将断吉凶</p>
        <div class="cc-tags">
          <span class="cat-tag">三传四课</span>
          <span class="cat-tag">六神</span>
          <span class="cat-tag">五行神将</span>
          <span class="cat-tag">贵神课体</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== BAZI SECTION ===== -->
<section class="section" id="section-bazi">
  <div class="section-header">
    <span class="sh-symbol" style="color:var(--cyan)">🌟</span>
    <h2 class="sh-title">八字命盘</h2>
    <p class="sh-en">Four Pillars of Destiny</p>
    <p class="sh-desc">年柱映祖荫，月柱观父母，日干为本人，时柱知晚景。阴阳五行定命局，十神生克论人生。</p>
  </div>

  <div class="input-card">
    <h3>命主基本信息</h3>
    <div class="input-row">
      <input type="text" class="input-field" id="baziName" placeholder="姓名" maxlength="20">
      <input type="date" class="input-field" id="baziDate">
      <!-- 日历模式切换 -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
        <span style="font-size:12px;opacity:.5">历法</span>
        <label style="font-size:12px;cursor:pointer;display:flex;align-items:center;gap:4px">
          <input type="radio" name="calendarMode" value="solar" checked onchange="onCalendarModeChange()"> 公历
        </label>
        <label style="font-size:12px;cursor:pointer;display:flex;align-items:center;gap:4px">
          <input type="radio" name="calendarMode" value="lunar" onchange="onCalendarModeChange()"> 农历
        </label>
        <span id="calendarHint" style="font-size:11px;color:var(--gold);margin-left:4px">当前：公历输入</span>
      </div>
      <select class="input-field" id="baziHour" onchange="onShichenChange()">
        <option value="">时辰（选填）</option>
        <option value="23">子时 23:00-01:00（夜半）</option>
        <option value="1">丑时 01:00-03:00（鸡鸣）</option>
        <option value="3">寅时 03:00-05:00（平旦）</option>
        <option value="5">卯时 05:00-07:00（日出）</option>
        <option value="7">辰时 07:00-09:00（食时）</option>
        <option value="9">巳时 09:00-11:00（隅中）</option>
        <option value="11">午时 11:00-13:00（日中）</option>
        <option value="13">未时 13:00-15:00（日昳）</option>
        <option value="15">申时 15:00-17:00（晡时）</option>
        <option value="17">酉时 17:00-19:00（日入）</option>
        <option value="19">戌时 19:00-21:00（黄昏）</option>
        <option value="21">亥时 21:00-23:00（人定）</option>
      </select>
      <p class="input-hint" id="shichenHint">⚠️ 时辰按<b>农历</b>计算，每个时辰相当于2小时。以上时间对应农历时辰，公历时间仅作参考。</p>
      <p class="input-hint" style="cursor:pointer;color:var(--gold);font-size:11px" onclick="toggleShichenTable()">📋 时辰对照表（点击展开）</p>
      <!-- 时辰对照表（默认隐藏） -->
      <div id="shichenTable" style="display:none;margin-top:8px;padding:12px;background:rgba(201,168,76,.04);border-radius:8px;font-size:12px;line-height:1.8">
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px">
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>子时</b> 23:00-01:00<br><span style="opacity:.5">夜半·胆经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>丑时</b> 01:00-03:00<br><span style="opacity:.5">鸡鸣·肝经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>寅时</b> 03:00-05:00<br><span style="opacity:.5">平旦·肺经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>卯时</b> 05:00-07:00<br><span style="opacity:.5">日出·大肠经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>辰时</b> 07:00-09:00<br><span style="opacity:.5">食时·胃经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>巳时</b> 09:00-11:00<br><span style="opacity:.5">隅中·脾经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>午时</b> 11:00-13:00<br><span style="opacity:.5">日中·心经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>未时</b> 13:00-15:00<br><span style="opacity:.5">日昳·小肠经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>申时</b> 15:00-17:00<br><span style="opacity:.5">晡时·膀胱经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>酉时</b> 17:00-19:00<br><span style="opacity:.5">日入·肾经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>戌时</b> 19:00-21:00<br><span style="opacity:.5">黄昏·心包经当令</span></div>
          <div style="padding:4px 8px;background:rgba(201,168,76,.08);border-radius:4px"><b>亥时</b> 21:00-23:00<br><span style="opacity:.5">人定·三焦经当令</span></div>
        </div>
        <p style="margin-top:8px;opacity:.4;font-size:11px">注：农历以子时（23:00）为一日之始，与公历0:00为一日之始不同。排盘时请以出生地地方时为准。</p>
      </div>
      <select class="input-field" id="baziSex">
        <option value="male">男</option>
        <option value="female">女</option>
      </select>
    </div>
    <p class="input-hint">出生日期为公历。时辰不填则按中午12:00计算。</p>
    <button class="compute-btn" onclick="computeBazi()" id="baziBtn">排 盘 演 命</button>
  </div>

  <div class="result" id="baziResult">
    <div class="result-banner">
      <h2 class="rb-name" id="baziNameOut"></h2>
      <p class="rb-meta" id="baziMetaOut"></p>
      <div class="rb-tags" id="baziTagsOut"></div>
    </div>

    <!-- PILLAR CHART -->
    <div class="pillar-chart">
      <div class="pillar-header">
        <div class="ph-col">年柱</div>
        <div class="ph-col">月柱</div>
        <div class="ph-col">日柱</div>
        <div class="ph-col">时柱</div>
      </div>
      <div class="pillar-row">
        <div class="pr-col">
          <p class="pr-label">天干 · 地支</p>
          <p class="pr-gan gan-甲" id="bz0g"></p>
          <p class="pr-zhi zhi-子" id="bz0z"></p>
          <p class="pr-ele" id="bz0e"></p>
          <p class="pr-na" id="bz0n"></p>
        </div>
        <div class="pr-col">
          <p class="pr-label">天干 · 地支</p>
          <p class="pr-gan gan-甲" id="bz1g"></p>
          <p class="pr-zhi zhi-子" id="bz1z"></p>
          <p class="pr-ele" id="bz1e"></p>
          <p class="pr-na" id="bz1n"></p>
        </div>
        <div class="pr-col">
          <p class="pr-label">天干 · 地支</p>
          <p class="pr-gan gan-甲" id="bz2g"></p>
          <p class="pr-zhi zhi-子" id="bz2z"></p>
          <p class="pr-ele" id="bz2e"></p>
          <p class="pr-na" id="bz2n"></p>
        </div>
        <div class="pr-col">
          <p class="pr-label">天干 · 地支</p>
          <p class="pr-gan gan-甲" id="bz3g"></p>
          <p class="pr-zhi zhi-子" id="bz3z"></p>
          <p class="pr-ele" id="bz3e"></p>
          <p class="pr-na" id="bz3n"></p>
        </div>
