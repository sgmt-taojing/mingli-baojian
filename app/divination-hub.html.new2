        <p>道法自然、无为而治<br>适合：重视养生、自然、自由者</p>
      </div>
      <div class="faith-card" onclick="selectFaith('fo')">
        <div class="faith-icon">🪷</div>
        <h4>佛家</h4>
        <p>慈悲智慧、离苦得乐<br>适合：重视修行、因果、慈悲者</p>
      </div>
      <div class="faith-card" onclick="selectFaith('all')">
        <div class="faith-icon">📿</div>
        <h4>兼修</h4>
        <p>儒道释兼修、圆融通达<br>适合：包容并蓄、广学多闻者</p>
      </div>
    </div>
  </div>

  <!-- B. 八字绑定 -->
  <div class="user-bazi-bind" id="userBaziBind" style="display:none">
    <h4>绑定八字（可选，用于精准穿搭建议）</h4>
    <p>系统将根据您的五行喜用神，推荐每日穿搭颜色</p>
    <div class="input-row">
      <input class="input-field" id="userBaziName" placeholder="姓名">
      <input type="date" class="input-field" id="baziBirthday">
      <select class="input-field" id="userBaziHour">
        <option value="">出生时辰</option>
        <option value="23">子时 23:00-01:00</option>
        <option value="1">丑时 01:00-03:00</option>
        <option value="3">寅时 03:00-05:00</option>
        <option value="5">卯时 05:00-07:00</option>
        <option value="7">辰时 07:00-09:00</option>
        <option value="9">巳时 09:00-11:00</option>
        <option value="11">午时 11:00-13:00</option>
        <option value="13">未时 13:00-15:00</option>
        <option value="15">申时 15:00-17:00</option>
        <option value="17">酉时 17:00-19:00</option>
        <option value="19">戌时 19:00-21:00</option>
        <option value="21">亥时 21:00-23:00</option>
      </select>
    </div>
    <button class="compute-btn" onclick="bindBazi()">绑 定</button>
  </div>

  <!-- C. 年度参拜提醒日程表 -->
  <div class="calendar-section" id="calendarSection" style="display:none">
    <h4>📅 年度参拜提醒</h4>
    <div class="reminder-list" id="reminderList"></div>
  </div>

  <!-- D1. 参拜指南 -->
  <div class="worship-guide" id="worshipGuide" style="display:none">
    <h4>🙏 参拜指南</h4>
    <div class="faith-tabs" id="worshipFaithTabs" style="display:flex;gap:0;margin-bottom:20px;border-bottom:1px solid rgba(201,168,76,.08)">
      <button class="jinang-tab active" onclick="showWorship('ru')">儒家</button>
      <button class="jinang-tab" onclick="showWorship('dao')">道家</button>
      <button class="jinang-tab" onclick="showWorship('fo')">��家</button>
    </div>
    <div id="worshipContent" class="worship-content"></div>
    <div class="worship-nav" style="display:flex;justify-content:center;gap:16px;margin-top:20px">
      <button class="compute-btn" onclick="prevWorshipStep()" id="worshipPrevBtn" style="padding:10px 24px;font-size:12px">◀ 上一步</button>
      <button class="compute-btn" onclick="nextWorshipStep()" id="worshipNextBtn" style="padding:10px 24px;font-size:12px">下一步 ▶</button>
    </div>
    <div class="worship-motto" id="worshipMotto" style="text-align:center;margin-top:24px;padding:16px;background:rgba(201,168,76,0.05);border:1px solid rgba(201,168,76,0.1)">
      <p style="font-size:14px;letter-spacing:4px;font-family:'Ma Shan Zheng',serif;color:var(--gold)"></p>
    </div>
  </div>

  <!-- D. 每日穿搭建议 -->
  <div class="daily-outfit" id="dailyOutfit" style="display:none">
    <h4>👔 每日穿搭建议</h4>
    <div class="outfit-card" id="outfitCard"></div>
  </div>

  <!-- E. 每日注意事项 -->
  <div class="daily-advice" id="dailyAdvice" style="display:none">
    <h4>📋 每日注意事项</h4>
    <div id="adviceList"></div>
  </div>

  <!-- F. 提醒设置 -->
  <div class="reminder-settings" id="reminderSettings" style="display:none">
    <h4>提醒设置</h4>
    <label><input type="checkbox" id="notifyBrowser" checked> 浏览器通知（参拜日前3天提醒）</label>
    <label><input type="checkbox" id="notifyEmail"> 邮件提醒（需绑定邮箱）</label>
    <label><input type="checkbox" id="notifyOutfit" checked> 每日穿搭建议（早上7点推送）</label>
    <label><input type="checkbox" id="notifyQuote" checked> 好记用语（每日一句）</label>
    <label><input type="checkbox" id="notifyDailyWorship"> 每日参拜提醒（早6:00推送当日宜拜神佛+口诀）</label>
    <label><input type="checkbox" id="notifyShichen"> 时辰提醒（重要时辰推送，如子时静坐、午时用膳）</label>
    <p class="input-hint" style="font-size:11px;color:var(--gold);margin:4px 0 0 8px">时辰提醒基于您的绑定八字时辰，按农历十二时辰推送养生建议。</p>
    <label><input type="checkbox" id="notifyJiri" checked> 吉日提醒（黄道吉日推送+当日宜做事项）</label>
  </div>
</section>

<!-- ===== LUOPAN SECTION ===== -->
<section class="section" id="section-luopan">
  <div class="section-header">
    <span class="sh-symbol" style="color:var(--gold)">🧭</span>
    <h2 class="sh-title">电 子 罗 盘</h2>
    <p class="sh-en">Digital Compasses · Qimen · LiuRen · XuanKong · BaZhai</p>
    <p class="sh-desc">将古老罗盘电子化，输入数据即出盘。奇门遁甲盘、六壬神盘、玄空飞星盘、八宅明镜盘、河图洛书盘，随时起盘，即时呈现。</p>
  </div>

  <div class="input-card">
    <h3>通用输入</h3>
    <div class="input-row">
      <input type="text" class="input-field" id="lpName" placeholder="姓名（可选）" maxlength="20">
      <input type="date" class="input-field" id="lpDate">
      <select class="input-field" id="lpHour">
        <option value="">时辰（自动）</option>
        <option value="23">子时 23-01</option>
        <option value="1">丑时 01-03</option>
        <option value="3">寅时 03-05</option>
        <option value="5">卯时 05-07</option>
        <option value="7">辰时 07-09</option>
        <option value="9">巳时 09-11</option>
        <option value="11">午时 11-13</option>
        <option value="13">未时 13-15</option>
        <option value="15">申时 15-17</option>
        <option value="17">酉时 17-19</option>
        <option value="19">戌时 19-21</option>
        <option value="21">亥时 21-23</option>
      </select>
    </div>
  </div>

  <!-- COMPASS TYPE SELECTOR -->
  <div class="compass-selector">
    <div class="cs-item active" onclick="selectCompass('qimen')" id="cs-qimen">
      <p class="cs-symbol">☰</p>
      <p class="cs-name">奇门遁甲</p>
      <p class="cs-en">Qimen Compass</p>
    </div>
    <div class="cs-item" onclick="selectCompass('liuren')" id="cs-liuren">
      <p class="cs-symbol">⬡</p>
      <p class="cs-name">六壬神盘</p>
      <p class="cs-en">Liu Ren Compass</p>
    </div>
    <div class="cs-item" onclick="selectCompass('xuankong')" id="cs-xuankong">
      <p class="cs-symbol">✦</p>
      <p class="cs-name">玄空飞星</p>
      <p class="cs-en">Xuan Kong Fei Xing</p>
    </div>
    <div class="cs-item" onclick="selectCompass('bazhai')" id="cs-bazhai">
      <p class="cs-symbol">☷</p>
      <p class="cs-name">八宅明镜</p>
      <p class="cs-en">Ba Zhai Ming Jing</p>
    </div>
    <div class="cs-item" onclick="selectCompass('hetuluo')" id="cs-hetuluo">
      <p class="cs-symbol">◎</p>
      <p class="cs-name">河图洛书</p>
      <p class="cs-en">He Tu Luo Shu</p>
    </div>
    <div class="cs-item" onclick="selectCompass('yaogua')" id="cs-yaogua">
      <p class="cs-symbol">䷀</p>
      <p class="cs-name">六爻金钱</p>
      <p class="cs-en">Liu Yao Compass</p>
    </div>
  </div>

  <!-- COMPASS DISPLAY AREA -->
  <div class="compass-wrap">
    <div class="compass-center">
      <canvas id="compassCanvas" width="640" height="640"></canvas>
      <div class="compass-title-overlay" id="compassTitleOverlay"></div>
    </div>
  </div>

  <!-- COMPASS CONTROL -->
  <div class="compass-controls">
    <div class="cc-hint" id="ccHint">选择罗盘类型，点击「起盘」查看</div>
    <button class="compute-btn" onclick="renderCompass()" id="lpBtn">电 子 起 盘</button>
  </div>

  <!-- COMPASS LEGEND -->
  <div id="compassLegend" style="display:none">
    <div class="interp-card gold-accent" style="margin-top:30px">
      <h5>罗 盘 读 法</h5>
      <p id="lpLegendText" style="white-space:pre-line;font-size:13px;opacity:.7;line-height:2"></p>
    </div>
    <div class="interp-card violet-accent" style="margin-top:12px">
      <h5>格 局 释 义</h5>
      <p id="lpJieShi" style="white-space:pre-line;font-size:13px;opacity:.7;line-height:2"></p>
    </div>
  </div>

  <div class="back-row">
    <button class="back-btn" onclick="showSection('hero')">返 回 首 页</button>
  </div>
</section>

</div><!-- /main -->


