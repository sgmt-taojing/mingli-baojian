  <!-- B. 简易风水评分 -->
  <div class="fs-section">
    <div class="input-card">
      <h3>🔢 简易风水评分</h3>
      <p style="text-align:center;font-size:12px;opacity:.4;margin-bottom:20px;letter-spacing:2px">无需户型图，输入宅子基本信息即可</p>
      <div class="input-row">
        <select class="input-field" id="fsHuxing">
          <option value="">选择户型</option>
          <option value="1室1厅">一室一厅</option>
          <option value="2室1厅">两室一厅</option>
          <option value="2室2厅">两室两厅</option>
          <option value="3室1厅">三室一厅</option>
          <option value="3室2厅">三室两厅</option>
          <option value="4室2厅">四室两厅</option>
          <option value="别墅">别墅</option>
        </select>
        <select class="input-field" id="fsChaoxiang">
          <option value="">选择朝向</option>
          <option value="南">南</option>
          <option value="北">北</option>
          <option value="东">东</option>
          <option value="西">西</option>
          <option value="东南">东南</option>
          <option value="西南">西南</option>
          <option value="东北">东北</option>
          <option value="西北">西北</option>
        </select>
        <input type="number" class="input-field" id="fsLouceng" placeholder="楼层（如6）" min="1" max="99">
      </div>
      <div class="input-row">
        <input type="number" class="input-field" id="fsYear" placeholder="出生年份（如1990）" min="1900" max="2030">
        <select class="input-field" id="fsSex">
          <option value="">选择性别</option>
          <option value="male">男</option>
          <option value="female">女</option>
        </select>
      </div>
      <div style="text-align:center;margin-top:20px">
        <button class="btn-primary" onclick="computeFengshui()">🧮 开始评分</button>
      </div>
      <div class="result fs-result" id="fsResult">
        <div id="fsOutput"></div>
      </div>
    </div>
  </div>

  <!-- C. 八宅风水分析 -->
  <div class="fs-section">
    <div class="input-card">
      <h3>🧭 八宅风水 · 命卦分析</h3>
      <p style="text-align:center;font-size:12px;opacity:.4;margin-bottom:20px;letter-spacing:2px">根据出生年份与性别计算命卦，判断吉凶方位</p>
      <div class="input-row">
        <input type="number" class="input-field" id="bzYear" placeholder="出生年份（如1990）" min="1900" max="2030">
        <select class="input-field" id="bzSex">
          <option value="">选择性别</option>
          <option value="male">男</option>
          <option value="female">女</option>
        </select>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;margin-top:12px">
        <input type="text" id="bzName" class="input-field" placeholder="姓名（选填，用于命卦计算）" style="flex:1;min-width:120px">
        <input type="number" id="bzMonth" class="input-field" placeholder="月" min="1" max="12" style="width:60px">
        <input type="number" id="bzDay" class="input-field" placeholder="日" min="1" max="31" style="width:60px">
        <select class="input-field" id="bzHour" style="min-width:120px">
          <option value="">时辰</option>
          <option value="23">子时（23:00-01:00）</option>
          <option value="1">丑时（01:00-03:00）</option>
          <option value="3">寅时（03:00-05:00）</option>
          <option value="5">卯时（05:00-07:00）</option>
          <option value="7">辰时（07:00-09:00）</option>
          <option value="9">巳时（09:00-11:00）</option>
          <option value="11">午时（11:00-13:00）</option>
          <option value="13">未时（13:00-15:00）</option>
          <option value="15">申时（15:00-17:00）</option>
          <option value="17">酉时（17:00-19:00）</option>
          <option value="19">戌时（19:00-21:00）</option>
          <option value="21">亥时（21:00-23:00）</option>
        </select>
      </div>
      <div style="text-align:center;margin-top:20px">
        <button class="btn-primary" onclick="computeBaZhai()">🧭 分析命卦</button>
      </div>
      <div class="result fs-result" id="bzResult">
        <div id="bzOutput"></div>
      </div>
    </div>
  </div>

