<meta name="mobile-web-app-capable" content="yes">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'><rect width='180' height='180' rx='36' fill='%23080808'/><text x='50%25' y='54%25' dominant-baseline='middle' text-anchor='middle' font-size='100' font-family='serif'>☰</text></svg>">
<title>易道智鉴 · 先进AI推演</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&family=Ma+Shan+Zheng&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/divination-hub.css?v=20260703">
</head>
<body>

<!-- PWA INSTALL BANNER -->
<div id="pwaInstallBanner" style="display:none;position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(201,168,76,0.95);color:#080808;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;font-size:13px;letter-spacing:1px;backdrop-filter:blur(8px)">
  <span style="font-family:'Ma Shan Zheng',serif;font-size:15px;letter-spacing:3px">📱 易道智鉴</span>
  <span style="flex:1;margin:0 16px;font-size:12px;opacity:0.7">添加到主屏幕，随时查阅</span>
  <div style="display:flex;gap:8px">
    <button onclick="installPWA()" style="padding:6px 16px;background:#080808;color:var(--gold);border:none;font-family:'Noto Serif SC',serif;font-size:12px;letter-spacing:2px;cursor:pointer;border-radius:3px">安装</button>
    <button onclick="dismissPWA()" style="padding:6px 12px;background:transparent;color:#080808;border:1px solid #080808;font-family:'Noto Serif SC',serif;font-size:12px;letter-spacing:2px;cursor:pointer;border-radius:3px">×</button>
  </div>
</div>

<!-- LOADING -->
<div class="loading-overlay" id="loadingOverlay">
  <p class="loading-text">推　命　中</p>
  <p class="loading-sub">天地之数，运于无形</p>
</div>

<!-- NAV -->
<nav class="top-nav">
  <div class="nav-inner">
    <div class="nav-brand">易道智鉴</div>
    <div class="nav-tabs">
      <button class="nav-tab" onclick="showSection('hero')" id="tab-hero">
        <span class="tab-emoji">🏠</span>
