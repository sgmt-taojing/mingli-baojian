      <input type="text" class="input-field" id="yjName" placeholder="姓名（可选）" maxlength="20">
    </div>
    <div class="input-row" style="margin-top:12px;gap:12px;justify-content:center">
      <button class="compute-btn" onclick="yjStart('person')" id="yjBtnP">人　盘</button>
      <button class="compute-btn" onclick="yjStart('matter')" id="yjBtnM">事　盘</button>
    </div>
  </div>

  <div id="yjDivArea" style="display:none">
    <div class="input-card" style="text-align:center;padding:40px">
      <h3 style="margin-bottom:8px;font-size:16px">金 钱 课</h3>
      <p style="font-size:11px;opacity:.35;letter-spacing:2px;margin-bottom:30px">一念至诚，三掷金钱，显象分明</p>
      <div class="coins-row">
        <div class="coin" id="yjC0">背</div>
        <div class="coin" id="yjC1">背</div>
        <div class="coin" id="yjC2">背</div>
      </div>
      <div class="line-dots">
        <div class="ldot" id="yjD0"></div>
        <div class="ldot" id="yjD1"></div>
        <div class="ldot" id="yjD2"></div>
        <div class="ldot" id="yjD3"></div>
        <div class="ldot" id="yjD4"></div>
        <div class="ldot" id="yjD5"></div>
      </div>
      <button class="compute-btn" onclick="yjCast()" id="yjCastBtn">掷 钱 问 卦</button>
      <p id="yjCount" style="margin-top:14px;font-size:11px;opacity:.35;letter-spacing:2px">第 1 / 6 爻</p>
    </div>
  </div>

  <div class="result" id="yjResult">
    <div class="result-banner">
      <p style="font-size:12px;letter-spacing:5px;color:var(--gold);opacity:.5;margin-bottom:12px" id="yjMeta"></p>
      <h2 class="rb-name" style="font-size:clamp(36px,7vw,56px)" id="yjTitle"></h2>
      <p style="font-size:14px;color:var(--gold);font-style:italic;letter-spacing:3px" id="yjPinyin"></p>
    </div>

    <div class="hexagram-row">
      <div class="hg-card" id="yjPrimary">
        <p class="hg-label">本　卦</p>
        <p class="hg-symbol" id="yjSym1"></p>
        <div class="gua-lines" id="yjGua1"></div>
        <p class="hg-name" id="yjName1"></p>
        <p class="hg-pinyin" id="yjPy1"></p>
        <p class="hg-judgment" id="yjJud1"></p>
        <p class="hg-meaning" id="yjMean1"></p>
      </div>
      <div class="arrow-div">→</div>
      <div class="hg-card changed" id="yjChanged" style="display:none">
        <p class="hg-label">变　卦</p>
