  <div class="result" id="lrResult">
    <div class="result-banner">
      <p style="font-size:12px;letter-spacing:5px;color:var(--orange);opacity:.6;margin-bottom:10px" id="lrMeta"></p>
      <h2 class="rb-name">六壬神课</h2>
      <p style="font-size:13px;opacity:.4;letter-spacing:3px;margin-top:8px" id="lrSub"></p>
    </div>

    <div id="lrInterp"></div>

    <div id="lrReadingBox"></div>

    <div class="back-row">
      <button class="back-btn" onclick="showSection('hero')">返 回 首 页</button>
    </div>
  </div>
</section>

<!-- ===== KNOWLEDGE ===== -->
<section class="section" id="section-knowledge">
  <div class="section-header">
    <span class="sh-symbol" style="color:var(--gold)">📚</span>
    <h2 class="sh-title">易 学 知 识 库</h2>
    <p class="sh-en">Knowledge Base · I Ching · BaZi · Qimen · FengShui</p>
    <p class="sh-desc">从零开始学习易经八卦、八字命理、奇门遁甲、六爻占卜、紫微斗数、梅花易数、大六壬、风水基础，适合初学者系统入门。</p>
  </div>
  <div class="section-body" style="max-width:1200px;margin:0 auto;">
    <iframe src="divination-knowledge.html" style="width:100%;height:calc(100vh - 280px);min-height:600px;border:none;border-radius:4px;"></iframe>
  </div>
</section>

<!-- ===== CEZI SECTION (测字) ===== -->
<section class="section" id="section-cezi">
  <div class="section-header">
    <span class="sh-symbol" style="color:var(--gold)">✍️</span>
    <h2 class="sh-title">测 字 解 析</h2>
    <p class="sh-en">Character Divination ·拆字 · 五行 · 数理</p>
    <p class="sh-desc">输入一字，拆解字形字义，洞悉命运玄机。拆字法始于秦汉，问事断吉凶，灵验异常。</p>
  </div>

  <div class="input-card">
    <h3>请输入一字</h3>
    <p class="input-hint">手写或输入一个汉字</p>
    <div class="input-row">
      <input type="text" class="input-field" id="ceziInput" placeholder="请输入一个汉字" maxlength="1" style="font-size:32px;width:120px;text-align:center;font-family:'Ma Shan Zheng',serif" oninput="if(this.value.length>1)this.value=this.value[0]">
      <button class="compute-btn" onclick="doCezi()" style="display:block;margin:0">开始解析</button>
    </div>
    <div class="input-row" style="margin-top:16px">
      <button class="compute-btn" onclick="randomCezi()" style="background:rgba(201,168,76,0.1);border-color:rgba(201,168,76,0.3);color:var(--gold2)">🎲 随机取字</button>
    </div>
  </div>

  <div class="result" id="ceziResult">
    <div class="result-banner">
      <h2 class="rb-name" id="ceziChar"></h2>
      <div class="rb-tags" id="ceziTags"></div>
    </div>
    <div class="analysis-grid" id="ceziAnalysis"></div>
  </div>
</section>

<!-- ===== HUAJIE SECTION ===== -->
<section class="section" id="section-huajie">
  <div class="section-header">
    <span class="sh-symbol" style="color:var(--gold)">🛡️</span>
    <h2 class="sh-title">开运化解</h2>
    <p class="sh-en">Fortune Enhancement</p>
    <p class="sh-desc">知命改运，趋吉避凶。五行补缺、方位调运、化煞开运，为您量身定制开运方案。</p>
  </div>

  <div class="input-card">
    <h3>命主信息 · 化解方案生成</h3>
    <div class="input-row">
      <input type="text" class="input-field" id="hjName" placeholder="姓名" maxlength="20">
      <input type="date" class="input-field" id="hjDate">
      <select class="input-field" id="hjHour">
        <option value="">时辰（选填）</option>
        <option value="23">子时 23:00-01:00</option>
        <option value="1">丑时 01:00-03:00</option>
        <option value="3">寅时 03:00-05:00</option>
        <option value="5">卯时 05:00-07:00</option>
        <option value="7">辰时 07:00-09:00</option>
        <option value="9">巳时 09:00-11:00</option>
        <option value="11">午时 11:00-13:00</option>
        <option value="13">未时 13:00-15:00</option>
        <option value="15">申时 15:00-17:00</option>
        <option value="17">酉时 17:00-19:00</option>
        <option value="19">戌时 19:00-21:00</option>
        <option value="21">亥时 21:00-23:00</option>
      </select>
      <select class="input-field" id="hjSex">
        <option value="male">男</option>
        <option value="female">女</option>
      </select>
    </div>
    <p class="input-hint">出生日期为公历。时辰不填则按中午12:00计算。</p>
    <button class="compute-btn" onclick="computeHuajie()" id="hjBtn" style="border-color:var(--gold);color:var(--gold)">生 成 化 解 方 案</button>
  </div>

  <div class="result" id="hjResult">
    <div id="hjOutput"></div>
    <div class="back-row">
      <button class="export-btn" onclick="exportHuajieReport()">📋 导出化解方案</button>
      <button class="back-btn" onclick="showSection('hero')">返 回 首 页</button>
    </div>
  </div>
</section>

<!-- ===== FENGSHUI SECTION ===== -->
<section class="section" id="section-fengshui">
  <div class="section-header">
    <span class="sh-symbol" style="color:var(--jade)">🏡</span>
    <h2 class="sh-title">宅 子 风 水</h2>
    <p class="sh-en">Feng Shui · BaZhai · XuanKong FeiXing</p>
    <p class="sh-desc">八宅明镜定吉凶，玄空飞星观气运。上传户型图分析宅子风水，或输入宅子信息进行简易评分，趋吉避凶，宅运亨通。</p>
  </div>

  <!-- A. 户型图上传分析 -->
  <div class="fs-section">
    <div class="input-card">
      <h3>📐 户型图风水分析</h3>
      <p style="text-align:center;font-size:12px;opacity:.4;margin-bottom:20px;letter-spacing:2px">上传户型图，智能分析采光与布局</p>
      <div class="fs-upload" id="fsUploadZone" onclick="document.getElementById('fsFloorPlan').click()">
        <div style="font-size:48px;margin-bottom:12px">🏠</div>
        <p style="font-size:13px;letter-spacing:2px;opacity:.6">点击上传户型图</p>
        <p style="font-size:11px;opacity:.3;margin-top:4px">支持 JPG / PNG</p>
        <input type="file" accept="image/*" id="fsFloorPlan" onchange="handleFloorPlanUpload(event)">
      </div>
      <img id="fsPreview" class="fs-preview" style="display:none">
      <div class="result" id="fsFloorResult" style="display:none">
        <div id="fsFloorOutput"></div>
      </div>
    </div>
  </div>

  <!-- B+. 好户型参考图库 -->
  <div class="fs-section">
    <div class="input-card">
      <h3>🏠 好户型参考图库</h3>
      <p style="text-align:center;font-size:12px;opacity:.4;margin-bottom:20px;letter-spacing:2px">经典好户型参考，点击卡片展开详细分析</p>
      <div class="plan-gallery-scroll">

        <!-- 户型1：方正三居室（最吉） -->
        <div class="plan-card" onclick="togglePlanDetail(this)">
          <div class="plan-header">
            <span class="plan-name">户型1：方正三居室（最吉）</span>
            <span class="plan-rating">⭐⭐⭐⭐⭐</span>
          </div>
          <div class="floor-plan fp1" style="grid-template-areas:'study hallway kitchen' 'room2 living washroom' 'master living balcony'">
            <div class="floor-room 吉位" style="grid-area:study"><span class="room-name">书房</span><span class="room-tag 吉位">北·文昌</span></div>
            <div class="floor-room" style="grid-area:hallway"><span class="room-name">走道</span></div>
            <div class="floor-room" style="grid-area:kitchen"><span class="room-name">厨房</span><span class="room-tag">西北</span></div>
            <div class="floor-room" style="grid-area:room2"><span class="room-name">次卧</span><span class="room-tag">东北</span></div>
            <div class="floor-room 吉位" style="grid-area:living"><span class="room-name">🪷 客厅</span><span class="room-tag 吉位">中宫·吉</span></div>
            <div class="floor-room" style="grid-area:washroom"><span class="room-name">卫生间</span><span class="room-tag">西南</span></div>
            <div class="floor-room 吉位" style="grid-area:master"><span class="room-name">主卧</span><span class="room-tag 吉位">东南·财位</span></div>
            <div class="floor-room" style="grid-area:balcony"><span class="room-name">阳台</span><span class="room-tag">南·桃花</span></div>
          </div>
          <div class="plan-brief">坐北朝南 · 120㎡ · 评分95/100</div>
          <div class="plan-detail">
            <div class="plan-info-grid">
              <div><strong>朝向</strong> 坐北朝南</div>
              <div><strong>面积</strong> 120㎡</div>
              <div><strong>评分</strong> 95/100</div>
              <div><strong>适合</strong> 乾命、兑命</div>
            </div>
            <div class="plan-desc"><strong>布局：</strong>客厅居中，主卧东南，次卧东北，书房正北，厨房西北，卫生间西南</div>
            <div class="plan-tags">
