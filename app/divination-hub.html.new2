              <span class="tag auspicious">📚 文昌位（正北）</span>
              <span class="tag auspicious">🌸 桃花位（正南）</span>
              <span class="tag inauspicious">👻 五鬼位（正西）→放绿植化解</span>
            </div>
            <div class="plan-dimensions">
              <div class="dim-bar"><span class="dim-label">方正度</span><span class="dim-track"><span class="dim-fill" style="width:95%"></span></span><span class="dim-num">95</span></div>
              <div class="dim-bar"><span class="dim-label">采光</span><span class="dim-track"><span class="dim-fill" style="width:90%"></span></span><span class="dim-num">90</span></div>
              <div class="dim-bar"><span class="dim-label">通风</span><span class="dim-track"><span class="dim-fill" style="width:85%"></span></span><span class="dim-num">85</span></div>
