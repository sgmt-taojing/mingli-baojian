<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>易道智鉴 · 后台管理</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500;600;700&family=Ma+Shan+Zheng&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#080808;--ink2:#111;--ink3:#1a1a1a;--ink4:#222;
  --paper:#f0e8d8;--paper2:#d4c9b0;--paper3:#a09080;
  --gold:#c9a84c;--gold2:#e8cc7a;--gold3:#a08030;
  --cinn:#c0392b;--cinn2:#e74c3c;
  --jade:#27ae60;--jade2:#2ecc71;
  --cyan:#2980b9;--cyan2:#5dade2;
  --wood:#8d6e63;
  --amber:#f39c12;
  --cream:#fdf6e3;
  --gold-bright:#D4AF37;
  --danger:#dc3545;
  --gray-light:#aaa;--gray:#888;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Noto Serif SC',serif;background:var(--ink);color:var(--paper);min-height:100vh;line-height:1.7}
a{color:var(--gold2);text-decoration:none}
a:hover{color:var(--gold-bright)}

.topbar{position:sticky;top:0;z-index:100;background:linear-gradient(135deg,var(--ink2) 0%,var(--ink3) 100%);border-bottom:2px solid var(--gold3);box-shadow:0 2px 20px rgba(201,168,76,.15)}
.topbar-inner{max-width:1400px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:.6rem 1.5rem;flex-wrap:wrap;gap:.5rem}
.topbar-title{font-family:'Ma Shan Zheng',cursive;font-size:1.5rem;color:var(--gold2);display:flex;align-items:center;gap:.5rem}
.topbar-title .sub{font-family:'Noto Serif SC';font-size:.8rem;color:var(--gray-light);font-weight:300}
.topbar-nav{display:flex;gap:.3rem;flex-wrap:wrap}
.topbar-nav a{padding:.4rem .9rem;border-radius:6px;font-size:.85rem;color:var(--paper2);transition:all .2s;white-space:nowrap}
.topbar-nav a:hover,.topbar-nav a.active{background:var(--gold3);color:var(--ink)}

.container{max-width:1400px;margin:0 auto;padding:1.5rem}
.section{display:none;animation:fadeIn .3s ease}
.section.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.section-header{margin-bottom:1.5rem;padding-bottom:.8rem;border-bottom:1px solid var(--ink4)}
.section-header h2{font-family:'ZCOOL XiaoWei',serif;font-size:1.6rem;color:var(--gold2)}
.section-header p{color:var(--gray-light);font-size:.85rem;margin-top:.3rem}

.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
.card{background:linear-gradient(135deg,var(--ink2),var(--ink3));border:1px solid var(--ink4);border-radius:10px;padding:1.2rem;transition:all .25s;position:relative;overflow:hidden}
.card:hover{border-color:var(--gold3);box-shadow:0 4px 20px rgba(201,168,76,.1);transform:translateY(-2px)}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold3),transparent);opacity:0;transition:opacity .25s}
.card:hover::before{opacity:1}
.card h3{font-family:'ZCOOL XiaoWei',serif;color:var(--gold2);font-size:1.1rem;margin-bottom:.6rem}
.card .meta{font-size:.75rem;color:var(--gray-light)}
.card .stat{font-size:1.8rem;font-weight:700;color:var(--gold-bright);margin:.3rem 0}
.card .stat small{font-size:.8rem;color:var(--gray-light);font-weight:300}

.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--ink4)}
table{width:100%;border-collapse:collapse;font-size:.85rem}
thead{background:var(--ink2)}
th{padding:.7rem .8rem;text-align:left;color:var(--gold2);font-weight:500;border-bottom:2px solid var(--gold3);white-space:nowrap}
td{padding:.6rem .8rem;border-bottom:1px solid var(--ink3);color:var(--paper2)}
tr:hover td{background:var(--ink2)}

.badge{display:inline-block;padding:.15rem .6rem;border-radius:10px;font-size:.7rem;font-weight:500}
.badge-ok{background:rgba(39,174,96,.2);color:var(--jade2);border:1px solid var(--jade)}
.badge-warn{background:rgba(243,156,18,.2);color:var(--amber);border:1px solid var(--amber)}
.badge-err{background:rgba(220,53,69,.2);color:var(--danger);border:1px solid var(--danger)}
.badge-info{background:rgba(41,128,185,.2);color:var(--cyan2);border:1px solid var(--cyan)}
.badge-gold{background:rgba(201,168,76,.2);color:var(--gold2);border:1px solid var(--gold3)}

input,select,textarea{background:var(--ink);border:1px solid var(--ink4);border-radius:6px;padding:.5rem .8rem;color:var(--paper);font-family:inherit;font-size:.85rem;outline:none;transition:border-color .2s}
input:focus,select:focus,textarea:focus{border-color:var(--gold3)}
input::placeholder{color:var(--gray)}
.btn{display:inline-block;padding:.5rem 1.2rem;border-radius:6px;cursor:pointer;border:none;font-family:inherit;font-size:.85rem;font-weight:500;transition:all .2s}
.btn-primary{background:var(--gold3);color:var(--ink)}
.btn-primary:hover{background:var(--gold2)}
.btn-outline{background:transparent;border:1px solid var(--gold3);color:var(--gold2)}
.btn-outline:hover{background:var(--gold3);color:var(--ink)}

.search-bar{display:flex;gap:.5rem;margin-bottom:1rem;align-items:center;flex-wrap:wrap}
.search-bar input{flex:1;min-width:200px}

.engine-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;margin-bottom:1.5rem}
.engine-card{background:linear-gradient(135deg,var(--ink2),var(--ink3));border:1px solid var(--ink4);border-radius:10px;padding:1rem;cursor:pointer;transition:all .25s}
.engine-card:hover{border-color:var(--gold3);transform:translateY(-2px)}
.engine-card .engine-name{font-family:'ZCOOL XiaoWei',serif;font-size:1.1rem;color:var(--gold2);margin-bottom:.3rem}
.engine-card .engine-desc{font-size:.75rem;color:var(--gray-light)}
.engine-card .engine-icon{font-size:1.5rem;float:right}

.test-panel{background:var(--ink2);border:1px solid var(--ink4);border-radius:8px;padding:1.2rem;margin-top:1rem}
.test-panel .form-row{display:flex;gap:.8rem;align-items:center;flex-wrap:wrap;margin-bottom:.6rem}
.test-panel label{font-size:.8rem;color:var(--gold2);min-width:60px}
.test-panel input,.test-panel select{width:auto;min-width:80px}
#paipanResult{background:var(--ink);border:1px solid var(--ink3);border-radius:6px;padding:1rem;margin-top:1rem;max-height:500px;overflow-y:auto;font-size:.8rem;line-height:1.6;white-space:pre-wrap;word-break:break-all}
#paipanResult .key{color:var(--gold2)}
#paipanResult .val{color:var(--paper2)}
#paipanResult .err{color:var(--danger)}

.guide-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem}
.guide-card{background:linear-gradient(135deg,var(--ink2),var(--ink3));border:1px solid var(--ink4);border-radius:10px;padding:1.2rem;transition:all .25s;margin-bottom:1rem}
.guide-card:hover{border-color:var(--gold3);box-shadow:0 4px 16px rgba(201,168,76,.1)}
.guide-card h3{font-family:'ZCOOL XiaoWei',serif;color:var(--gold2);font-size:1.1rem;margin-bottom:.6rem;display:flex;align-items:center;gap:.4rem}
.guide-card .guide-content{font-size:.82rem;color:var(--paper2);line-height:1.8}
.guide-card .guide-content .item{padding:.4rem 0;border-bottom:1px dashed var(--ink4)}
.guide-card .guide-content .item:last-child{border-bottom:none}
.guide-card .guide-content .label{color:var(--gold2);font-weight:500}
.guide-card .guide-content .time{color:var(--cyan2);font-size:.75rem}

.shichen-table th,.shichen-table td{font-size:.8rem;text-align:center}
.shichen-table .time-col{color:var(--cyan2);font-weight:500;white-space:nowrap}

.jieqi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.8rem}
.jieqi-card{background:var(--ink2);border:1px solid var(--ink4);border-radius:8px;padding:.8rem;border-left:3px solid var(--gold3)}
.jieqi-card .jq-name{font-family:'ZCOOL XiaoWei';color:var(--gold2);font-size:1rem}
.jieqi-card .jq-info{font-size:.75rem;color:var(--paper2);margin-top:.3rem}
.jieqi-card .jq-info .lbl{color:var(--cyan2)}

.taboo-list{list-style:none}
.taboo-list li{padding:.5rem .8rem;margin-bottom:.4rem;background:var(--ink);border-radius:6px;border-left:3px solid var(--cinn);font-size:.82rem}
.taboo-list li .reason{color:var(--gray-light);font-size:.75rem;display:block;margin-top:.2rem}

.faith-tabs{display:flex;gap:.3rem;margin-bottom:1rem}
.faith-tab{padding:.4rem 1rem;border-radius:6px;cursor:pointer;font-size:.85rem;background:var(--ink2);color:var(--paper2);border:1px solid var(--ink4);transition:all .2s}
.faith-tab.active{background:var(--gold3);color:var(--ink);border-color:var(--gold3)}

.content-block{background:var(--ink2);border:1px solid var(--ink4);border-radius:8px;padding:1rem;margin-bottom:1rem}
.content-block h3{font-family:'ZCOOL XiaoWei';color:var(--gold2);font-size:1rem;margin-bottom:.6rem}
.quote-item{padding:.5rem .8rem;margin-bottom:.3rem;background:var(--ink);border-radius:6px;border-left:3px solid var(--gold3);font-size:.82rem}
.quote-item .src{color:var(--gray-light);font-size:.72rem}

.monitor-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:1rem}
.service-card{background:var(--ink2);border:1px solid var(--ink4);border-radius:8px;padding:1rem;display:flex;align-items:center;justify-content:space-between}
.service-card .svc-name{font-size:.9rem;color:var(--paper)}
.service-card .svc-status{width:10px;height:10px;border-radius:50%;display:inline-block;margin-right:.5rem}
.dot-ok{background:var(--jade2);box-shadow:0 0 6px var(--jade2)}
.dot-err{background:var(--danger);box-shadow:0 0 6px var(--danger)}
.dot-unk{background:var(--gray)}

.progress-bar{height:6px;background:var(--ink);border-radius:3px;overflow:hidden;margin-top:.3rem}
.progress-bar .fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--gold3),var(--gold2));transition:width .5s}

footer{text-align:center;padding:2rem 1rem;border-top:1px solid var(--ink4);margin-top:2rem;font-size:.75rem;color:var(--gray-light)}
footer a{color:var(--gold2);margin:0 .5rem}

@media(max-width:768px){
  .topbar-inner{padding:.5rem .8rem}
  .topbar-nav a{padding:.3rem .5rem;font-size:.75rem}
  .container{padding:.8rem}
  .card-grid{grid-template-columns:1fr}
  .engine-grid{grid-template-columns:1fr}
  .guide-grid{grid-template-columns:1fr}
  .topbar-title{font-size:1.1rem}
  .topbar-title .sub{display:none}
}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--ink)}
::-webkit-scrollbar-thumb{background:var(--ink4);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--gold3)}
.spinner{display:inline-block;width:16px;height:16px;border:2px solid var(--ink4);border-top-color:var(--gold2);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.highlight{background:rgba(201,168,76,.15);border-radius:3px;padding:0 .2rem}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <div class="topbar-title">☰ 易道智鉴 <span class="sub">· 后台管理</span></div>
    <nav class="topbar-nav">
      <a href="#" data-section="engine" class="active">🔧 引擎测试台</a>
      <a href="#" data-section="knowledge">📚 知识库管理</a>
      <a href="#" data-section="guide">🧎 信众指导中心</a>
      <a href="#" data-section="content">📝 内容管理</a>
      <a href="#" data-section="monitor">📊 系统监控</a>
      <a href="divination-hub.html">🏠 返回主站</a>
    </nav>
  </div>
</div>

<div class="container">

<!-- 1. 引擎测试台 -->
<section id="section-engine" class="section active">
  <div class="section-header">
    <h2>🔧 引擎测试台</h2>
    <p>各排盘引擎调试入口 — 输入参数验证输出正确性</p>
  </div>
  <div class="engine-grid" id="engineGrid"></div>
  <div class="test-panel">
    <h3 style="font-family:'ZCOOL XiaoWei';color:var(--gold2);margin-bottom:.8rem">排盘测试</h3>
    <div class="form-row">
      <label>引擎</label>
      <select id="engineType"><option value="bazi">八字排盘</option><option value="ziwei">紫微斗数</option><option value="qimen">奇门遁甲</option><option value="liuyao">六爻排盘</option><option value="meihua">梅花易数</option><option value="liuren">六壬神课</option></select>
    </div>
    <div class="form-row">
      <label>年份</label><input type="number" id="paipanYear" value="1990" min="1900" max="2100">
      <label>月份</label><input type="number" id="paipanMonth" value="6" min="1" max="12">
      <label>日期</label><input type="number" id="paipanDay" value="15" min="1" max="31">
    </div>
    <div class="form-row">
      <label>时辰</label><input type="number" id="paipanHour" value="12" min="0" max="23">
      <label>分钟</label><input type="number" id="paipanMinute" value="0" min="0" max="59">
      <label>性别</label>
      <select id="paipanSex"><option value="male">男</option><option value="female">女</option></select>
    </div>
    <div class="form-row">
      <label>农历</label><input type="checkbox" id="paipanLunar">
      <label>经度</label><input type="number" id="paipanLng" placeholder="如:116.4" step="0.01" style="width:80px">
    </div>
    <div class="form-row">
      <button class="btn btn-primary" onclick="runPaipanTest()">⚡ 执行排盘</button>
      <button class="btn btn-outline" onclick="clearPaipanResult()">清除</button>
      <span id="paipanStatus" style="font-size:.8rem;color:var(--gray-light)"></span>
    </div>
    <div id="paipanResult">等待执行排盘...</div>
  </div>
</section>

<!-- 2. 知识库管理 -->
<section id="section-knowledge" class="section">
  <div class="section-header">
    <h2>📚 知识库管理</h2>
    <p>16领域知识库统计 · 卡片数 · 总字符数 · 达标率</p>
  </div>
  <div class="search-bar">
    <input type="text" id="kbSearch" placeholder="搜索知识内容（如：天干、五行、格局、观音...）" oninput="searchKnowledge()">
    <button class="btn btn-outline" onclick="exportKbStats()">导出统计</button>
  </div>
  <div class="card-grid" id="kbStatsGrid"></div>
  <div id="kbSearchResult" style="margin-top:1rem"></div>
  <div id="kbPendingList" style="margin-top:1.5rem"></div>
</section>

<!-- 3. 信众指导中心 -->
<section id="section-guide" class="section">
  <div class="section-header">
    <h2>🧎 信众指导中心</h2>
    <p>从实战出发 — 每日修行 · 参拜指导 · 养生时辰 · 节气养生 · 经文诵读 · 禁忌提醒</p>
  </div>

  <div class="guide-card">
    <h3>🌅 每日修行指引</h3>
    <div id="dailyPracticeContent"><p style="color:var(--gray-light);font-size:.85rem">加载中...</p></div>
    <div class="faith-tabs" style="margin-top:1rem" id="dpTabs">
      <div class="faith-tab active" onclick="switchDailyPractice('ru',this)">儒家</div>
      <div class="faith-tab" onclick="switchDailyPractice('dao',this)">道家</div>
      <div class="faith-tab" onclick="switchDailyPractice('fo',this)">佛家</div>
    </div>
  </div>

  <div class="guide-card">
    <h3>🛐 参拜指导手册</h3>
    <div class="faith-tabs" id="worshipTabs">
      <div class="faith-tab active" onclick="switchWorshipGuide('general',this)">通用礼仪</div>
      <div class="faith-tab" onclick="switchWorshipGuide('buddhist',this)">佛教</div>
      <div class="faith-tab" onclick="switchWorshipGuide('taoist',this)">道教</div>
      <div class="faith-tab" onclick="switchWorshipGuide('confucian',this)">儒家</div>
    </div>
    <div id="worshipGuideContent"></div>
  </div>

  <div class="guide-card">
    <h3>🕐 养生时辰指引</h3>
    <p style="font-size:.8rem;color:var(--gray-light);margin-bottom:.8rem">12时辰对应脏腑经络 · 养生建议 · 宜忌事项</p>
    <div class="table-wrap">
      <table class="shichen-table">
        <thead><tr><th>时辰</th><th>时间</th><th>经络</th><th>脏腑</th><th>养生建议</th><th>宜</th><th>忌</th></tr></thead>
        <tbody id="shichenBody"></tbody>
      </table>
    </div>
  </div>

  <div class="guide-card">
    <h3>🌿 节气养生指导</h3>
    <p style="font-size:.8rem;color:var(--gray-light);margin-bottom:.8rem">24节气养生重点 · 食疗方 · 功法建议</p>
    <div class="jieqi-grid" id="jieqiGrid"></div>
  </div>

  <div class="guide-card">
    <h3>📖 经文诵读指引</h3>
    <div class="faith-tabs" id="scriptureTabs">
      <div class="faith-tab active" onclick="switchScripture('buddhist',this)">佛教</div>
      <div class="faith-tab" onclick="switchScripture('taoist',this)">道教</div>
      <div class="faith-tab" onclick="switchScripture('confucian',this)">儒家</div>
    </div>
    <div id="scriptureContent"></div>
  </div>

  <div class="guide-card">
    <h3>⚠️ 信众禁忌提醒</h3>
    <div class="faith-tabs" id="tabooTabs">
      <div class="faith-tab active" onclick="switchTaboo('buddhist',this)">佛教禁忌</div>
      <div class="faith-tab" onclick="switchTaboo('taoist',this)">道教禁忌</div>
      <div class="faith-tab" onclick="switchTaboo('confucian',this)">儒家禁忌</div>
    </div>
    <div id="tabooContent"></div>
  </div>
</section>

<!-- 4. 内容管理 -->
<section id="section-content" class="section">
  <div class="section-header">
    <h2>📝 内容管理</h2>
    <p>每日口诀 · 智慧语录 · 生肖运势</p>
  </div>
  <div class="content-block">
    <h3>📜 每日口诀管理</h3>
    <div class="search-bar">
      <input type="text" id="koujueSearch" placeholder="搜索口诀名称或内容..." oninput="searchKoujue()">
      <select id="koujueCategory" onchange="filterKoujue()"><option value="">全部分类</option></select>
      <span id="koujueCount" style="font-size:.8rem;color:var(--gray-light)"></span>
    </div>
    <div id="koujueList" style="max-height:500px;overflow-y:auto"></div>
  </div>
  <div class="content-block">
    <h3>💬 智慧语录管理</h3>
    <div class="search-bar">
      <input type="text" id="quoteSearch" placeholder="搜索语录..." oninput="searchQuotes()">
      <select id="quoteCategory" onchange="filterQuotes()"><option value="">全部分类</option></select>
      <span id="quoteCount" style="font-size:.8rem;color:var(--gray-light)"></span>
    </div>
    <div id="quoteList" style="max-height:500px;overflow-y:auto"></div>
  </div>
  <div class="content-block">
    <h3>🐉 生肖运势管理 — 2025乙巳蛇年</h3>
    <div id="zodiacList"></div>
  </div>
</section>

<!-- 5. 系统监控 -->
<section id="section-monitor" class="section">
  <div class="section-header">
    <h2>📊 系统监控</h2>
    <p>服务状态 · 文件统计 · 最近变更</p>
  </div>
  <div class="monitor-grid" id="monitorGrid"></div>
  <div class="content-block" style="margin-top:1.5rem">
    <h3>📁 文件统计</h3>
    <div id="fileStats"></div>
  </div>
  <div class="content-block">
    <h3>🔄 最近变更</h3>
    <div id="recentChanges"></div>
  </div>
</section>

</div>

<footer>
  <p>易道智鉴 · 后台管理系统 · v2026.06.24</p>
  <p><a href="divination-hub.html">主站</a> | <a href="disclaimer.html">免责声明</a> | <a href="knowledge-panel.html">知识面板</a></p>
</footer>

<script src="knowledge/authoritative-knowledge-base.js"></script>
<script src="knowledge/zodiac-complete.js"></script>
<script src="knowledge/wisdom-quotes.js"></script>
<script src="knowledge/koujue-database-full.js"></script>
<script src="knowledge/faith-knowledge-base.js"></script>
<script src="knowledge/faith-guide.js"></script>
<script>
// Bridge: merge FAITH_GUIDE data into FAITH_KNOWLEDGE for admin compatibility
if(typeof FAITH_GUIDE!=='undefined'){
  if(typeof FAITH_KNOWLEDGE==='undefined')window.FAITH_KNOWLEDGE={};
  else window.FAITH_KNOWLEDGE=FAITH_KNOWLEDGE;
  var fg=FAITH_GUIDE;
  // Convert dailyPractice format: {buddhist:{morning:{title,steps},...}} → {buddhist:{schedule:[{period,practice,intention,method}]}}
  var dpMap={buddhist:'buddhist',taoist:'taoist',confucian:'confucian'};
  var dpAdmin={};
  Object.keys(dpMap).forEach(function(k){
    var src=fg.dailyPractice[k];
    if(src){
      var schedule=[];
      ['morning','noon','evening'].forEach(function(t){
        if(src[t]){
          schedule.push({period:src[t].title,practice:src[t].steps.join('；'),intention:'修身养性',method:src[t].steps.slice(0,2).join('；')});
        }
      });
      dpAdmin[k]={title:k==='buddhist'?'佛教修行':k==='taoist'?'道教修持':'儒家修身',subtitle:'每日三时功课',schedule:schedule};
    }
  });
  // Add ru/dao/fo aliases
  if(dpAdmin.confucian)dpAdmin.ru=dpAdmin.confucian;
  if(dpAdmin.taoist)dpAdmin.dao=dpAdmin.taoist;
  if(dpAdmin.buddhist)dpAdmin.fo=dpAdmin.buddhist;
  window.FAITH_KNOWLEDGE.dailyPractices=dpAdmin;
  // Merge other guide data with correct field names for admin
  // worshipManual → also merge into worshipGuide for detailed per-faith data
  var wm=fg.worshipManual||{};
  if(!window.FAITH_KNOWLEDGE.worshipGuide)window.FAITH_KNOWLEDGE.worshipGuide={};
  // Add detailed worship manual as worshipManual
  window.FAITH_KNOWLEDGE.worshipManual=wm;
  // Enrich specificGuidance with manual data
  if(window.FAITH_KNOWLEDGE.worshipGuide.specificGuidance){
    Object.keys(wm).forEach(function(k){
      if(wm[k]&&wm[k].procedure){
        var sg=window.FAITH_KNOWLEDGE.worshipGuide.specificGuidance;
        sg[k]=(sg[k]||'')+(sg[k]?'\n':'')+wm[k].title+'：'+wm[k].procedure.join('→');
      }
    });
  }
  window.FAITH_KNOWLEDGE.shichenGuide=fg.shichenGuide;
  window.FAITH_KNOWLEDGE.jieqiGuide=fg.jieqiGuide;
  // Convert scriptureGuide: {buddhist:[{name,level,...}]} → {buddhist:[{name,source, intro,...}]}
  var sg=fg.scriptureGuide||{};
  var sgAdmin={};
  Object.keys(sg).forEach(function(k){
    if(Array.isArray(sg[k])){
      sgAdmin[k]=sg[k].map(function(s){return{name:s.name,source:s.level+'·'+s.duration,intro:s.benefit,text:s.method,usage:s.benefit,merit:s.benefit}});
    }
  });
  window.FAITH_KNOWLEDGE.scriptures=sgAdmin;
  // Convert tabooReminders: {buddhist:[{category,items:[]}]} → {buddhist:{title,items:[{taboo,reason,severity}]}}
  var tr=fg.tabooReminders||{};
  var trAdmin={};
  Object.keys(tr).forEach(function(k){
    if(Array.isArray(tr[k])){
      var items=[];
      tr[k].forEach(function(cat){
        if(cat.items&&Array.isArray(cat.items)){
          cat.items.forEach(function(it){items.push({taboo:typeof it==='string'?it:it.taboo||it,reason:typeof it==='string'?cat.category:it.reason||it.detail||'',severity:'中'})});
        }
      });
      trAdmin[k]={title:k==='buddhist'?'佛教禁忌':k==='taoist'?'道教禁忌':'儒家禁忌',items:items};
    }
  });
  // Add ru/dao/fo aliases
  if(trAdmin.confucian)trAdmin.ru=trAdmin.confucian;
  if(trAdmin.taoist)trAdmin.dao=trAdmin.taoist;
  if(trAdmin.buddhist)trAdmin.fo=trAdmin.buddhist;
  window.FAITH_KNOWLEDGE.taboos=trAdmin;
}
</script>

