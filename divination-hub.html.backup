  html += '• 可提前在年初制定还愿计划，年底前完成本年度所有许愿还愿';
  html += '</div></div>';
  
  return html;
}

function toggleHuajieDetail(el) {
  const content = el.querySelector('.month-detail-content');
  if (content.style.display === 'none') {
    content.style.display = 'block';
  } else {
    content.style.display = 'none';
  }
}

