            <div class="floor-room" style="grid-area:kitchen"><span class="room-name">厨房</span><span class="room-tag">东北</span></div>
            <div class="floor-room" style="grid-area:pantry"><span class="room-name">储物</span></div>
            <div class="floor-room" style="grid-area:bathroom"><span class="room-name">卫生间</span><span class="room-tag">西北</span></div>
            <div class="floor-room" style="grid-area:hallway"><span class="room-name">玄关</span></div>
          </div>
          <div class="plan-brief">坐南朝北 · 85㎡ · 评分90/100</div>
          <div class="plan-detail">
            <div class="plan-info-grid">
              <div><strong>朝向</strong> 坐南朝北</div>
              <div><strong>面积</strong> 85㎡</div>
              <div><strong>评分</strong> 90/100</div>
