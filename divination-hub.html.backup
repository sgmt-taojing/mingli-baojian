    <button class="guide-toggle" onclick="toggleGuide()" style="background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);color:var(--gold);padding:6px 14px;font-size:12px;letter-spacing:2px;cursor:pointer;font-family:'Noto Serif SC',serif;border-radius:4px">收起 ▲</button>
