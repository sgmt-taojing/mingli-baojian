function analyzeChar(char) {
  const data = CEZI_DATA[char];
  if (!data) {
    // 动态计算未收录的字
    const strokes = char.length > 0 ? (char.charCodeAt(0) % 81) + 1 : 1;
    let radical = char[0];
    let wuxing = CEZI_RADICAL_ELE[radical] || '土';
    return {
      char: char,
      radical: radical,
      wuxing: wuxing,
      strokes: strokes,
      meaning: '字含深意，需细参详',
      career: '字显贵气，事业可期',
      marriage: '良缘天成，婚事可定',
      health: '气血调和，身体无恙',
      wealth: '财气盈盈，理财可得',
      mnemonic: '字如其人，自求多福'
    };
  }
  return {...data, char: char};
}

function doCezi() {
  const char = document.getElementById('ceziInput').value.trim();
  if (!char) {
    showToast('请输入一个字');
    return;
  }
  const result = analyzeChar(char);
  document.getElementById('ceziChar').textContent = result.char;
  document.getElementById('ceziTags').innerHTML = 
    '<span class="rb-tag">' + result.radical + '部</span>' +
    '<span class="rb-tag">' + result.wuxing + '行</span>' +
    '<span class="rb-tag">' + result.strokes + '画</span>';
  
  const luckNum = (result.strokes % 81) || result.strokes;
  const luck = luckNum <= 30 ? '大吉' : luckNum <= 50 ? '中吉' : luckNum <= 70 ? '小吉' : luckNum <= 81 ? '吉' : '平';
  
  document.getElementById('ceziAnalysis').innerHTML = `
    <div class="cezi-analysis-card" style="border-color:rgba(201,168,76,.15)">
      <h5>字形拆解</h5>
      <p class="ca-desc">${result.char} = ${result.radical} + ${result.char.length > 1 ? result.char[1] : '·'}</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(39,174,96,.15)">
      <h5>五行归属</h5>
      <p class="ca-value">${result.wuxing}</p>
      <p class="ca-desc">根据部首${result.radical}判定五行</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(142,68,173,.15)">
      <h5>笔画数理</h5>
      <p class="ca-value">${result.strokes}画 · ${luck}</p>
      <p class="ca-desc">81数理中第${luckNum}数</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(201,168,76,.15)">
      <h5>字义解读</h5>
      <p class="ca-desc">${result.meaning}</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(41,128,185,.15)">
      <h5>事业</h5>
      <p class="ca-desc">${result.career}</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(231,76,60,.15)">
      <h5>婚姻</h5>
      <p class="ca-desc">${result.marriage}</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(39,174,96,.15)">
      <h5>健康</h5>
      <p class="ca-desc">${result.health}</p>
    </div>
    <div class="cezi-analysis-card" style="border-color:rgba(230,126,34,.15)">
      <h5>财运</h5>
      <p class="ca-desc">${result.wealth}</p>
    </div>
  `;
  
  document.getElementById('ceziResult').classList.add('visible');
}

function randomCezi() {
  const keys = Object.keys(CEZI_DATA);
  const char = keys[Math.floor(Math.random() * keys.length)];
  document.getElementById('ceziInput').value = char;
  doCezi();
}

