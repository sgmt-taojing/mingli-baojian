      <div style="font-family:'Ma Shan Zheng',serif;font-size:32px;color:var(--gold);margin-bottom:8px">①</div>
      <div style="font-size:15px;letter-spacing:3px;color:var(--paper2);margin-bottom:6px">输入出生信息</div>
      <div style="font-size:12px;opacity:.5;letter-spacing:1px">填写姓名、日期、时辰</div>
    </div>
    <div style="font-size:20px;color:var(--gold);opacity:.5;flex-shrink:0">→</div>
    <div class="guide-step" style="flex:1;min-width:200px;max-width:280px;padding:20px;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);border-radius:8px;text-align:center;cursor:pointer;transition:all .3s" onmouseover="this.style.borderColor='rgba(201,168,76,0.4)';this.style.background='rgba(201,168,76,0.05)'" onmouseout="this.style.borderColor='rgba(201,168,76,0.15)';this.style.background='rgba(255,255,255,0.03)'" onclick="showSection('bazi')">
      <div style="font-family:'Ma Shan Zheng',serif;font-size:32px;color:var(--gold);margin-bottom:8px">②</div>
