  庚:{比:'庚',劫:'辛',食:'壬',伤:'癸',财:'甲',才:'乙',官:'丙',杀:'丁',印:'戊',枭:'己'},
  辛:{比:'辛',劫:'庚',食:'癸',伤:'壬',财:'乙',才:'甲',官:'丁',杀:'丙',印:'己',枭:'戊'},
