  drawRing(ctx, cx, cy, 150, 'rgba(201,168,76,0.2)', null, 1);
  drawRing(ctx, cx, cy, 305, 'rgba(201,168,76,0.25)', null, 2);

  // Draw each palace
  for (let pal = 1; pal <= 9; pal++) {
