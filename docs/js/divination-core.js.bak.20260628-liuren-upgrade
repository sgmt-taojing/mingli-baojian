  // 根据日主五行与流月干支五行关系计算吉凶
  function computeMonthLuck(monthStem, monthZhi) {
    const stemEle = ELE[monthStem];
    const zhiEle = ZHI_ELE[monthZhi];
    // 综合月干月支五行
