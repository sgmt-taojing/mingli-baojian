function computeZiWeiStars(mingGongIdx, dayStemIdx) {
  const starOrder = ['紫微','天机','太阳','武曲','天相','廉贞','七杀','破军'];
  const baseIdx = (mingGongIdx - 1 + 12) % 12;
  const all = {};
  starOrder.forEach((sName, i) => {
    const pos = (baseIdx + i * 1) % 12;
    all[pos] = { name: sName, nature: ZW_STARS[sName]?.nature || '', desc: ZW_STARS[sName]?.desc || '' };
  });
  return {
    main: all[mingGongIdx] || { name: '紫微', nature: '帝王星', desc: '紫微星坐命宫' },
    all
  };
}

function computeFourChange(dayStemIdx) {
  const changes = [
    {lu:'禄',quan:'权',ke:'科',ji:'忌'},
    {lu:'权',quan:'科',ke:'忌',ji:'禄'},
    {lu:'科',quan:'忌',ke:'禄',ji:'权'},
    {lu:'忌',quan:'禄',ke:'权',ji:'科'},
  ];
  const idx = dayStemIdx % 4;
  const c = changes[idx];
  return { lu:c.lu, quan:c.quan, ke:c.ke, ji:c.ji };
}

