    html += '<div style="font-size:9px;opacity:.5;margin-top:2px">重点:' + m.luck + '</div>';
    html += '</div>';
  }
  html += '</div>';

  // 详细文字版(折叠)
  html += '<div style="margin-top:20px">';
  html += '<div class="huajie-alert" style="cursor:pointer" onclick="toggleHuajieDetail(this)">';
