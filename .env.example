# ═══ 命理宝鉴环境配置 ═══

# AI API密钥 (g2claw.com)
G2CLAW_API_KEY=***

# 推送服务API地址 (企业微信/钉钉/飞书机器人)
PUSH_API_BASE=

# 时区
TZ=Asia/Shanghai

# ═══ 安全配置 ═══

# 数据加密密钥（用于手机号等敏感字段加密存储，32字符以上）
# 生成方式: openssl rand -base64 32
MINGLI_ENCRYPT_KEY=

# JWT签名密钥（用于用户认证Token生成与验证，32字符以上）
# 生成方式: openssl rand -base64 32
MINGLI_JWT_SECRET=

# CORS允许的前端来源（多个用逗号分隔）
# 生产环境示例: https://mingli.example.com,https://admin.mingli.example.com
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# AI API基础地址（用于AI解卦、智能解读等功能）
AI_API_BASE=https://api.g2claw.com

# ═══ 端口配置 (默认值，一般不需要改) ═══
# Web前端: 8080
# AI API代理: 8900
# 排盘服务: 8911
# TTS语音: 8912
